{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JiraApi": {
    "BaseUrl": "",
    "Email": "",
    "ApiToken": ""
  },
  "JiraQuery": {
    "ProjectKeys": []
  },
  "JiraFilters": {
    "DefaultStatuses": [
      "Backlog",
      "To Do",
      "In Progress"
    ],
    "TeamMembers": [],
    "IncludeUnassignedByDefault": false,
    "Presets": [
      {
        "Name": "Sprint corrente",
        "Jql": "sprint in openSprints()"
      },
      {
        "Name": "Bug aperti",
        "Jql": "issuetype = Bug AND status NOT IN (Done, Closed, Cancelled)"
      },
      {
        "Name": "In ritardo",
        "Jql": "duedate < now() AND status NOT IN (Done, Closed, Cancelled)"
      }
    ]
  }
}
