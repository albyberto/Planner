{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JiraApi": {
    "BaseUrl": "",
    "Email": "",
    "ApiToken": ""
  },
  "CacheOptions": {
    "Projects": {
      "AbsoluteExpirationRelativeToNow": "24:00:00"
    },
    "Types": {
      "AbsoluteExpirationRelativeToNow": "24:00:00"
    },
    "Assignees": {
      "AbsoluteExpirationRelativeToNow": "24:00:00"
    },
    "Components": {
      "AbsoluteExpirationRelativeToNow": "1:00:00"
    },
    "Labels": {
      "AbsoluteExpirationRelativeToNow": "1:00:00"
    }
  },
  "JiraQuery": {
    "ProjectKeys": []
  },
  "JiraFilters": {
    "DefaultProject": "OPNMS",
    "Me": {
      "Email": "alberto.viezzi@euris.it"
    },
    "DefaultStatuses": [
      "Backlog",
      "To Do",
      "In Progress"
    ],
    "TeamMembers": [],
    "IncludeUnassignedByDefault": false,
    "Presets": [
      {
        "Name": "Sprint corrente",
        "Jql": "sprint in openSprints()"
      },
      {
        "Name": "Bug aperti",
        "Jql": "issuetype = Bug AND status NOT IN (Done, Closed, Cancelled)"
      },
      {
        "Name": "In ritardo",
        "Jql": "duedate < now() AND status NOT IN (Done, Closed, Cancelled)"
      }
    ]
  }
}