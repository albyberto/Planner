{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JiraApiOptions": {
    "BaseUrl": "",
    "Email": "",
    "ApiToken": ""
  },
  "CacheOptions": {
    "Projects": {
      "AbsoluteExpirationRelativeToNow": "24:00:00"
    },
    "Types": {
      "AbsoluteExpirationRelativeToNow": "24:00:00"
    },
    "Assignees": {
