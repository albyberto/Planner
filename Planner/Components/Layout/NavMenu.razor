@using Microsoft.Extensions.Options
@using Planner.Clients
@using Planner.Extensions
@using Planner.Model
@using Planner.Options

<MudNavMenu>
    <MudNavGroup Title="Dashboard" Icon="@Icons.Material.Filled.Dashboard" Expanded="true">
        <MudNavLink Href="/dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Groups">
            Team
        </MudNavLink>
        @foreach (var user in _members)
        {
            <MudNavLink Href="@($"/dashboard/{Uri.EscapeDataString(user.EmailAddress)}")"
                        Match="NavLinkMatch.All">
                <UserAvatar User="@user" Size="Size.Small" />
            </MudNavLink>
        }
        <MudNavLink Href="@UnassignedHref" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.PersonOff">
            Non Assegnate
        </MudNavLink>
    </MudNavGroup>
</MudNavMenu>

@inject JiraReadClient ReadClient
@inject IOptions<JiraFilterOptions> FilterOptions

@code {
    private const string UnassignedHref = $"/dashboard/{Constants.Unassigned}";
    private List<UserModel> _members = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var emails = FilterOptions.Value.TeamMembers
                .Select(m => m.Email)
                .ToArray();
            
            var users = await ReadClient.GetProjects().FindAssigneesByEmailsAsync(emails);

            _members = users
                .Where(user => emails.Contains(user.EmailAddress))
                .OrderBy(user => user.DisplayName)
                .ToList();
        }
        catch
        {
            // fallback: mostra solo Team e Non Assegnate
        }
    }
}
