@using Microsoft.Extensions.Options
@using Planner.Model
@using Planner.Options
@using Planner.Services

<MudNavMenu>
    <MudNavLink Href="/gantt" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.ViewTimeline">
        Gantt View
    </MudNavLink>
    
    <MudNavLink Href="/jira-chat" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Chat">
        Jira Chat
    </MudNavLink>

    <MudNavLink Href="/test" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Science">
        Test
    </MudNavLink>

    <MudNavGroup Title="Dashboard" Icon="@Icons.Material.Filled.Dashboard" Expanded="true">
        <MudNavLink Href="/dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Groups">
            Team
        </MudNavLink>
        @foreach (var user in _members)
        {
            <MudNavLink Href="@($"/dashboard/{Uri.EscapeDataString(user.EmailAddress)}")"
                        Match="NavLinkMatch.All">
                <UserAvatar User="@user" Size="Size.Small" />
            </MudNavLink>
        }
        <MudNavLink Href="@UnassignedHref" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.PersonOff">
            Non Assegnate
        </MudNavLink>
    </MudNavGroup>
</MudNavMenu>

