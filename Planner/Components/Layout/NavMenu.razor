@using Microsoft.Extensions.Options
@using Planner.Clients
@using Planner.Options

<MudNavMenu>
    <MudNavGroup Title="Dashboard" Icon="@Icons.Material.Filled.Dashboard" Expanded="true">
        <MudNavLink Href="/dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Groups">
            Team
        </MudNavLink>
        @foreach (var member in _members)
        {
            <MudNavLink Href="@($"/dashboard/{Uri.EscapeDataString(member.Email)}")"
                        Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Person">
                @member.DisplayName
            </MudNavLink>
        }
        <MudNavLink Href="@UnassignedHref" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.PersonOff">
            Non Assegnate
        </MudNavLink>
    </MudNavGroup>
</MudNavMenu>

@inject JiraClient Client
@inject IOptions<JiraFilterOptions> FilterOptions

@code {
    private record NavMember(string Email, string DisplayName);

    private const string UnassignedHref = $"/dashboard/{Constants.Unassigned}";
    private List<NavMember> _members = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var users = await Client.GetProjectAssigneesAsync();
            var emails = FilterOptions.Value.TeamMembers
                .Select(m => m.Email)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            _members = users
                .Where(user => emails.Contains(user.EmailAddress))
                .Select(user => new NavMember(user.EmailAddress, user.DisplayName))
                .OrderBy(nav => nav.DisplayName)
                .ToList();
        }
        catch
        {
            // fallback: mostra solo Team e Non Assegnate
        }
    }
}
