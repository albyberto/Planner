@using System.Collections.Immutable
@using Microsoft.Extensions.Options
@using Planner.Facades
@using Planner.Infrastructure.Domain
@using Planner.Model
@using Planner.Options
<MudNavMenu>
    <MudNavLink Href="/gantt" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.ViewTimeline">
        Gantt View
    </MudNavLink>

    <MudNavLink Href="/jira-chat" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Chat">
        Jira Chat
    </MudNavLink>

    <MudNavLink Href="/test" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Science">
        Test
    </MudNavLink>

    <MudNavLink Href="/presets" Match="NavLinkMatch.All" Icon="@Icons.Material.Outlined.Preview">
        Presets
    </MudNavLink>

    <MudNavLink Href="/menu-config" Match="NavLinkMatch.All" Icon="@Icons.Material.Outlined.Settings">
        Menu Config
    </MudNavLink>

    <MudNavGroup Title="Dashboard" Icon="@Icons.Material.Outlined.Dashboard" Expanded="true">
        <MudNavLink Href="/dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Outlined.Groups">
            Team
        </MudNavLink>
        <MudNavLink Href="@UnassignedHref" Match="NavLinkMatch.All" Icon="@Icons.Material.Outlined.PersonOff">
            Non Assegnate
        </MudNavLink>
    </MudNavGroup>

    @foreach (var config in _menuConfigs) {
        <MudNavGroup Title="@config.ProjectKey" Icon="@Icons.Material.Outlined.Folder" Expanded="true">
            @foreach (var email in config.Assignees) {
                var isUnassigned = email.Equals(Constants.Unassigned, StringComparison.OrdinalIgnoreCase);
                var icon = isUnassigned ? Icons.Material.Outlined.PersonOff : Icons.Material.Outlined.Person;
                var displayName = isUnassigned ? "Unassigned" : email;

                <MudNavLink Href="@($"/dashboard?project={Uri.EscapeDataString(config.ProjectKey)}&email={Uri.EscapeDataString(email)}")" Match="NavLinkMatch.All" Icon="@icon">
                    @displayName
                </MudNavLink>
            }
        </MudNavGroup>
    }
</MudNavMenu>

@inject ProjectFacade ProjectFacade
@inject MenuConfigFacade MenuConfigFacade
@inject IOptions<JiraFilterOptions> FilterOptions

@code {
    private const string UnassignedHref = $"/dashboard/{Constants.Unassigned}";
    private ImmutableArray<MenuConfigItem> _menuConfigs = [];

    protected override async Task OnInitializedAsync() {
        try {
            _menuConfigs = await MenuConfigFacade.GetAllAsync();
        }
        catch {
            // fallback: mostra solo Team e Non Assegnate
        }
    }
}
