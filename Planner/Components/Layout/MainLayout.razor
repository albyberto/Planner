@inherits LayoutComponentBase
@using Planner.Services
@using Microsoft.JSInterop
@implements IDisposable
@inject JiraNotificationService NotificationService
@inject IJSRuntime JS

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h5" Class="ml-3">Planner</MudText>
        <MudSpacer />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    protected override void OnInitialized()
    {
        NotificationService.OnNewComments += HandleNewComments;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeAsync<bool>("window.blazorPushNotifications.requestPermission");
            }
            catch { /* Ignore errors on first render */ }
        }
    }

    private void HandleNewComments(int count, string author, string issueKey)
    {
        InvokeAsync(async () =>
        {
            try
            {
                string title = count == 1 
                    ? $"Nuovo commento da {author} ({issueKey})" 
                    : $"Hai ricevuto {count} nuovi commenti in Jira Chat";
                    
                await JS.InvokeVoidAsync("window.blazorPushNotifications.showNotification", title, new
                {
                    body = "Clicca per visualizzare le ultime conversazioni",
                    icon = "favicon.png"
                });
            }
            catch { /* Ignore JS errors */ }
        });
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    public void Dispose()
    {
        NotificationService.OnNewComments -= HandleNewComments;
    }
}
