@using System.Collections.Immutable
@using Planner.Model
@using Planner.Facades
@inject ProjectFacade ProjectFacade
@inject IssueFacade Facade

<InlineMultiSelect TItem="ComponentModel" Issue="@Issue" Items="@Issue.Components"
    ItemsChanged="@((IReadOnlyCollection<ComponentModel> components) => Issue.Components = ImmutableArray.CreateRange(components))"
    LoadItemsAsync="@(async projectKey => await ProjectFacade.GetComponentsAsync(projectKey))"
    SaveActionAsync="@(async components => await Facade.UpdateComponentsAsync(Issue.Key, components))"
    Label="Components" ChipColor="Color.Primary" EmptyTooltip="Aggiungi Component" />

@code {
    [Parameter, EditorRequired]
    public required IIssue Issue { get; set; }
}
