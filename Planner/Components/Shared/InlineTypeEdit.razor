@using Planner.Clients
@using Planner.Domain
@inject JiraReadClient ReadClient
@inject JiraWriteClient WriteClient
@inject ISnackbar Snackbar

<MudMenu ActivationEvent="MouseEvent.LeftClick" Dense="true" AnchorOrigin="Origin.BottomLeft">
    <ActivatorContent>
        <MudTooltip Text="@($"{IssueType.Name} — click per cambiare")" Arrow="true">
            @if (!string.IsNullOrEmpty(IssueType.IconUrl))
            {
                <MudImage Src="@IssueType.IconUrl" Width="20" Height="20" Alt="@IssueType.Name" Class="d-inline-flex cursor-pointer" />
            }
        </MudTooltip>
    </ActivatorContent>
    <ChildContent>
        @if (_loading)
        {
            <MudMenuItem Disabled="true">
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> Caricamento...
            </MudMenuItem>
        }
        else
        {
            @foreach (var type in _types)
            {
                <MudMenuItem OnClick="() => ChangeType(type)">
                    @if (!string.IsNullOrEmpty(type.IconUrl))
                    {
                        <MudImage Src="@type.IconUrl" Width="16" Height="16" Alt="@type.Name" Class="mr-2 d-inline-flex" />
                    }
                    @type.Name
                </MudMenuItem>
            }
        }
    </ChildContent>
</MudMenu>

@code {
    [Parameter, EditorRequired] public required string IssueKey { get; set; }
    [Parameter, EditorRequired] public required IssueType IssueType { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }
    [CascadingParameter(Name = "RefreshIssues")] public Func<Task>? RefreshIssues { get; set; }

    private IReadOnlyList<IssueType> _types = [];
    private bool _loading;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        try
        {
            _types = await ReadClient.GetProjectIssueTypesAsync();
        }
        catch
        {
            _types = [];
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ChangeType(IssueType type)
    {
        if (type.Id == IssueType.Id) return;

        try
        {
            await WriteClient.UpdateIssueTypeAsync(IssueKey, type.Id);
            Snackbar.Add($"{IssueKey} tipo → {type.Name}", Severity.Success);
            if (OnChanged.HasDelegate) await OnChanged.InvokeAsync();
            if (RefreshIssues is not null) await RefreshIssues();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }
}

