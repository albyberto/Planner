@using Planner.Facades
@using Planner.Model

@inject IssueFacade Facade
@inject ISnackbar Snackbar

<InlineDateEdit @bind-Value="Issue.StartDate" OnSave="SaveAsync" />

@code {
    [Parameter, EditorRequired] public required IIssue Issue { get; set; }

    private async Task SaveAsync(DateOnly? newValue)
    {
        try
        {
            await Facade.UpdateStartDateAsync(Issue.Key, newValue);
            Snackbar.Add($"{Issue.Key} Start Date aggiornata", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore nel salvataggio: {ex.Message}", Severity.Error);
        }
    }
}
