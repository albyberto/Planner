@using System.Collections.Immutable
@using Microsoft.Extensions.Options
@using Planner.Clients
@using Planner.Domain
@using Planner.Extensions
@using Planner.Model
@using Planner.Options
<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudGrid>
        <MudItem xs="12" sm="4" md="4">
            <MudSelect T="string"
                       Label="Stati"
                       MultiSelection="true"
                       SelectedValues="Filter.Statuses"
                       SelectedValuesChanged="OnStatusChanged"
                       Variant="Variant.Outlined"
                       AnchorOrigin="Origin.BottomCenter"
                       Clearable="true"
                       MultiSelectionTextFunc="@(selected => GetSelectedStatuesText(selected))">
                @foreach (var status in _statuses)
                {
                    <MudSelectItem T="string" Value="@status.Name">@status.Name.ToTitleCase()</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="4" md="4">
            <MudSelect T="string"
                       Label="Assignee"
                       MultiSelection="true"
                       SelectedValues="Filter.Assignees"
                       SelectedValuesChanged="OnAssigneeChanged"
                       Variant="Variant.Outlined"
                       AnchorOrigin="Origin.BottomCenter"
                       Clearable="true"
                       MultiSelectionTextFunc="@(selected => GetSelectedAssigneesText(selected))">
                @foreach (var assignee in _assignees)
                {
                    <MudSelectItem T="string"
                                   Value="@assignee.EmailAddress">@assignee.DisplayName.ToTitleCase()</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    </MudGrid>
</MudPaper>

@inject IOptions<JiraFilterOptions> Options;
@inject JiraClient Client
@inject ISnackbar Snackbar

@code {
    [Parameter] public EventCallback<Filter> OnFilterChanged { get; set; }
    
    ImmutableList<Status> _statuses = [];
    ImmutableList<User> _assignees = [];

    public Filter Filter = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _statuses = await Client.GetProjectStatusesAsync();
            _assignees = await Client.GetProjectAssigneesAsync();

            var settings = Options.Value;
            var assignees = settings.TeamMembers.Select(member => member.Email).ToHashSet();
            var statuses = settings.DefaultStatuses;

            Filter = new(assignees, statuses);
        }
        catch (Exception exception)
        {
            Snackbar.Add("Errore durante il recupero dei dati da Jira.", Severity.Error);
            Console.WriteLine(exception.Message);
        }
    }

    private Task OnPresetChanged(string? value) => Task.CompletedTask;

    private async Task OnStatusChanged(IEnumerable<string> values)
    {
        Filter = Filter with { Statuses = values.ToHashSet() };
        await NotifyFilterChanged();
    }

    private async Task OnAssigneeChanged(IEnumerable<string> values)
    {
        Filter = Filter with { Assignees = values.ToHashSet() };
        await NotifyFilterChanged();
    }

    private string GetSelectedStatuesText(IReadOnlyCollection<string?>? statuses)
    {
        statuses ??= [];

        if (statuses.Count == 0) return string.Empty;

        var names = statuses
            .Where(status => !string.IsNullOrEmpty(status))
            .Select(status => status!.ToTitleCase());
        
        return string.Join(", ", names);
    }

    private string GetSelectedAssigneesText(IReadOnlyCollection<string?>? emails)
    {
        emails ??= [];
        
        if (emails.Count == 0) return string.Empty;

        var names = _assignees
            .Where(assignee => emails.Contains(assignee.EmailAddress))
            .Select(assignee => string.IsNullOrWhiteSpace(assignee.DisplayName) ? assignee.EmailAddress : assignee.DisplayName);

        return string.Join(", ", names);
    }
    
    private async Task NotifyFilterChanged()
    {
        if (OnFilterChanged.HasDelegate)
        {
            await OnFilterChanged.InvokeAsync(Filter);
        }
    }
}