@using System.Collections.Immutable
@using Microsoft.Extensions.Options
@using Planner.Clients
@using Planner.Domain
@using Planner.Extensions
@using Planner.Model
@using Planner.Options

<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudGrid>
        <MudItem xs="12" sm="4" md="4">
            <MudSelect T="string"
                       Label="Stati"
                       MultiSelection="true"
                       SelectedValues="Filter.Statuses"
                       SelectedValuesChanged="OnStatusChanged"
                       Variant="Variant.Outlined"
                       AnchorOrigin="Origin.BottomCenter"
                       Clearable="true"
                       MultiSelectionTextFunc="@(selected => GetSelectedStatuesText(selected))">
                @foreach (var status in _statuses)
                {
                    <MudSelectItem T="string" Value="@status.Name">@status.Name.ToTitleCase()</MudSelectItem>
                }
            </MudSelect>
        </MudItem>

        @if (ShowAssigneeFilter)
        {
            <MudItem xs="12" sm="4" md="4">
                <MudSelect T="string"
                           Label="Assignee"
                           MultiSelection="true"
                           SelectedValues="Filter.Assignees"
                           SelectedValuesChanged="OnAssigneeChanged"
                           Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter"
                           Clearable="true"
                           MultiSelectionTextFunc="@(selected => GetSelectedAssigneesText(selected))">
                    @foreach (var assignee in _assignees)
                    {
                        <MudSelectItem T="string" Value="@assignee.EmailAddress">@assignee.DisplayName.ToTitleCase()</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4" md="4" Class="d-flex align-center">
                <MudSwitch T="bool"
                           Label="Includi non assegnate"
                           Color="Color.Primary"
                           Value="Filter.IncludeUnassigned"
                           ValueChanged="OnUnassignedChanged"/>
            </MudItem>
        }
    </MudGrid>
</MudPaper>

@inject IOptions<JiraFilterOptions> Options
@inject JiraClient Client
@inject ISnackbar Snackbar

@code {
    [Parameter] public EventCallback<Filter> OnFilterChanged { get; set; }
    [Parameter] public HashSet<string>? ForcedAssignees { get; set; }
    [Parameter] public bool? ForcedIncludeUnassigned { get; set; }
    [Parameter] public bool ShowAssigneeFilter { get; set; } = true;

    private bool _isLoaded;
    private bool _firstRender = true;
    
    private ImmutableList<Status> _statuses = [];
    private ImmutableList<User> _assignees = [];

    public Filter Filter = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _statuses = await Client.GetProjectStatusesAsync();
            _assignees = await Client.GetProjectAssigneesAsync();
            _isLoaded = true;
        }
        catch
        {
            Snackbar.Add("Errore durante il recupero dei dati da Jira.", Severity.Error);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_isLoaded) return;

        var settings = Options.Value;

        // 1. Definiamo i valori attesi (se forzati dal parent ok, altrimenti i default delle options)
        var expectedAssignees = ForcedAssignees != null ? ForcedAssignees : settings.TeamMembers.Select(m => m.Email).ToHashSet();
        var expectedUnassigned = ForcedIncludeUnassigned != null ? ForcedIncludeUnassigned.Value : settings.IncludeUnassignedByDefault;
        var expectedStatuses = Filter.Statuses.Count > 0 ? Filter.Statuses : settings.DefaultStatuses.ToHashSet();

        // 2. Controlliamo se i valori dettati dal parent sono diversi dal nostro filtro in memoria
        var hasAssigneesChanged = !Filter.Assignees.SetEquals(expectedAssignees);
        var hasUnassignedChanged = Filter.IncludeUnassigned != expectedUnassigned;

        // 3. Se non c'è stata una vera variazione (e non è il primissimo render), fermiamo tutto! Nessun loop.
        if (!hasAssigneesChanged && !hasUnassignedChanged && !_firstRender) return;

        // 4. Aggiorniamo il nostro stato e notifichiamo la query solo in caso di vero cambiamento
        Filter = new(expectedAssignees, expectedStatuses, expectedUnassigned);
        _firstRender = false;

        await NotifyFilterChanged();
    }

    private async Task OnStatusChanged(IEnumerable<string> values)
    {
        Filter = Filter with { Statuses = values.ToHashSet() };
        await NotifyFilterChanged();
    }

    private async Task OnAssigneeChanged(IEnumerable<string> values)
    {
        Filter = Filter with { Assignees = values.ToHashSet() };
        await NotifyFilterChanged();
    }

    private async Task OnUnassignedChanged(bool value)
    {
        Filter = Filter with { IncludeUnassigned = value };
        await NotifyFilterChanged();
    }

    private static string GetSelectedStatuesText(IReadOnlyCollection<string?>? statuses)
    {
        statuses ??= [];
        if (statuses.Count == 0) return string.Empty;
        var names = statuses
            .Where(s => !string.IsNullOrEmpty(s))
            .Select(s => s!.ToTitleCase());
        return string.Join(", ", names);
    }

    private string GetSelectedAssigneesText(IReadOnlyCollection<string?>? emails)
    {
        emails ??= [];
        if (emails.Count == 0) return string.Empty;
        var names = _assignees
            .Where(a => emails.Contains(a.EmailAddress))
            .Select(a => string.IsNullOrWhiteSpace(a.DisplayName) ? a.EmailAddress : a.DisplayName);
        return string.Join(", ", names);
    }

    private Task NotifyFilterChanged() => OnFilterChanged.HasDelegate 
        ? OnFilterChanged.InvokeAsync(Filter) 
        : Task.CompletedTask;
}