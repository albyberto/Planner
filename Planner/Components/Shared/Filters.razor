@using Planner.Builders
@using Planner.Model
<MudGrid>
            <MudItem xs="12" md="4">
                <MudAutocomplete T="string" Label="Projects"
                                 Value="_searchCriteria.ProjectKey" ValueChanged="OnProjectChangedAsync"
                                 SearchFunc="SearchProjectsAsync" Variant="Variant.Outlined" Dense="true"
                                 Required="true" RequiredError="Il progetto è obbligatorio"
                                 MinCharacters="1" DebounceInterval="250" ResetValueOnEmptyText="true" Disabled="@_isLoading" />
            </MudItem>

            @* TIME FILTER (single menu / dropdown) *@
            <MudItem xs="12" sm="6" md="4">
                <MudMenu AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter" Open="_timeFilterPopoverOpen" OpenChanged="e => _timeFilterPopoverOpen = e">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="@(() => _timeFilterPopoverOpen = true)"
                                  StartIcon="@Icons.Material.Filled.DateRange" EndIcon="@Icons.Material.Filled.ArrowDropDown"
                                  Disabled="@_isLoading" FullWidth="true" Style="text-transform: none;">
                            @TimeFilterSummary
                        </MudButton>
                    </ActivatorContent>
                    <ChildContent>
                        <MudPaper Class="pa-4" Outlined="true" Style="min-width: 280px;">
                            <MudStack Spacing="3">
                                <MudText Typo="Typo.subtitle2">Time filter</MudText>

                                <MudSelect T="TimeFilterTarget" Label="Filter by"
                                           Value="@(_searchCriteria.TimeFilter?.Target ?? TimeFilterTarget.CreatedDate)"
                                           ValueChanged="OnTimeTargetChanged"
                                           Variant="Variant.Outlined" Dense="true" Disabled="@_isLoading">
                                    <MudSelectItem T="TimeFilterTarget" Value="TimeFilterTarget.CreatedDate">Created date</MudSelectItem>
                                    <MudSelectItem T="TimeFilterTarget" Value="TimeFilterTarget.ResolvedDate">Resolved/closed date</MudSelectItem>
                                    <MudSelectItem T="TimeFilterTarget" Value="TimeFilterTarget.StatusTransitionDate">Status changed to…</MudSelectItem>
                                </MudSelect>

                                @if (_searchCriteria.TimeFilter?.Target == TimeFilterTarget.StatusTransitionDate)
                                {
                                    <MudSelect T="string" Label="Status"
                                               Value="@_searchCriteria.TimeFilter?.StatusName"
                                               ValueChanged="OnTimeStatusChanged"
                                               Variant="Variant.Outlined" Dense="true" Disabled="@_isLoading">
                                        @foreach (var status in _statuses)
                                        {
                                            <MudSelectItem T="string" Value="@status.Name">@status.Name</MudSelectItem>
                                        }
                                    </MudSelect>
                                }

                                <MudText Typo="Typo.caption" Class="mt-1">Period</MudText>
                                <div class="d-flex flex-wrap gap-1">
                                    @foreach (var preset in new[] { RelativeTimePreset.None, RelativeTimePreset.Last7Days, RelativeTimePreset.Last30Days, RelativeTimePreset.ThisWeek, RelativeTimePreset.LastWeek, RelativeTimePreset.ThisMonth, RelativeTimePreset.LastMonth, RelativeTimePreset.CustomRange })
                                    {
                                        var label = preset switch
                                        {
                                            RelativeTimePreset.None => "None",
                                            RelativeTimePreset.Last7Days => "7d",
                                            RelativeTimePreset.Last30Days => "30d",
                                            RelativeTimePreset.ThisWeek => "This week",
                                            RelativeTimePreset.LastWeek => "Last week",
                                            RelativeTimePreset.ThisMonth => "This month",
                                            RelativeTimePreset.LastMonth => "Last month",
                                            RelativeTimePreset.CustomRange => "Custom",
                                            _ => preset.ToString()
                                        };
                                        var current = _searchCriteria.TimeFilter?.Preset ?? RelativeTimePreset.None;
                                        <MudChip T="string" Size="Size.Small" Variant="current == preset ? Variant.Filled : Variant.Outlined"
                                                 Color="current == preset ? Color.Primary : Color.Default"
                                                 OnClick="@(() => OnTimePresetChanged(preset))">@label</MudChip>
                                    }
                                </div>

                                @if ((_searchCriteria.TimeFilter?.Preset ?? RelativeTimePreset.None) == RelativeTimePreset.CustomRange)
                                {
                                    <MudStack Direction="Direction.Row" Spacing="2">
                                        <MudDatePicker Label="From" Dense="true"
                                                      Value="@_timeFrom"
                                                      ValueChanged="OnTimeFromChanged"
                                                      Disabled="@_isLoading"
                                                      DateFormat="yyyy-MM-dd" />
                                        <MudDatePicker Label="To" Dense="true"
                                                      Value="@_timeTo"
                                                      ValueChanged="OnTimeToChanged"
                                                      Disabled="@_isLoading"
                                                      DateFormat="yyyy-MM-dd" />
                                    </MudStack>
                                }

                                <MudDivider />
                                <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small" OnClick="ClearTimeFilter">Clear time filter</MudButton>
                            </MudStack>
                        </MudPaper>
                    </ChildContent>
                </MudMenu>
            </MudItem>

            @* STATUSES *@
            <MudItem xs="12" sm="6" md="4">
                <MudSelect T="string" Label="Statuses" MultiSelection="true"
                           SelectedValues="_searchCriteria.Statuses.Select(x => x.Value).ToList()"
                           SelectedValuesChanged="OnStatusesChanged"
                           Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter" Clearable="true" Dense="true"
                           MultiSelectionTextFunc="@(selected => selected is not null && selected.Count > 0 ? $"{selected.Count} selezionati" : string.Empty)"
                           Disabled="@_isLoading">
                    @foreach (var status in _statuses) { <MudSelectItem T="string" Value="@status.Name">@status.Name</MudSelectItem> }
                </MudSelect>
                <div class="d-flex flex-wrap gap-1 mt-2">
                    @foreach (var item in _searchCriteria.Statuses)
                    {
                        <MudChip T="string" Size="Size.Small" 
                                 Color="@(item.IsExcluded ? Color.Error : Color.Success)"
                                 Icon="@(item.IsExcluded ? Icons.Material.Filled.Block : Icons.Material.Filled.Check)"
                                 OnClick="@(() => ToggleStatus(item))" OnClose="@(() => RemoveStatus(item))">
                            @item.Value
                        </MudChip>
                    }
                </div>
            </MudItem>

            @* TYPES *@
            <MudItem xs="12" sm="6" md="4">
        <MudSelect T="string" Label="Types" MultiSelection="true"
                   SelectedValues="_searchCriteria.Types.Select(x => x.Value).ToList()"
                   SelectedValuesChanged="OnTypesChanged"
                   Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter" Clearable="true" Dense="true"
                   MultiSelectionTextFunc="@(selected => selected is not null && selected.Count > 0 ? $"{selected.Count} selezionati" : string.Empty)"
                   Disabled="@_isLoading">
            @foreach (var type in _types)
            {
                @* Cambiato Value da .Value a .Name *@
                <MudSelectItem T="string" Value="@type.Name">@type.Name</MudSelectItem>
            }
        </MudSelect>
        <div class="d-flex flex-wrap gap-1 mt-2">
            @foreach (var item in _searchCriteria.Types)
            {
                <MudChip T="string" Size="Size.Small"
                         Color="@(item.IsExcluded ? Color.Error : Color.Success)"
                         Icon="@(item.IsExcluded ? Icons.Material.Filled.Block : Icons.Material.Filled.Check)"
                         OnClick="@(() => ToggleType(item))" OnClose="@(() => RemoveType(item))">
                    @item.Value
                </MudChip>
            }
        </div>
    </MudItem>

    @* COMPONENTS - Ora ragiona per NOME *@
    <MudItem xs="12" sm="6" md="4">
        <MudSelect T="string" Label="Components" MultiSelection="true"
                   SelectedValues="_searchCriteria.Components.Select(x => x.Value).ToList()"
                   SelectedValuesChanged="OnComponentsChanged"
                   Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter" Clearable="true" Dense="true"
                   MultiSelectionTextFunc="@(selected => selected is not null && selected.Count > 0 ? $"{selected.Count} selezionati" : string.Empty)"
                   Disabled="@_isLoading">
            @foreach (var component in _components)
            {
                @* Cambiato Value da .Value a .Name *@
                <MudSelectItem T="string" Value="@component.Name">@component.Name</MudSelectItem>
            }
        </MudSelect>
        <div class="d-flex flex-wrap gap-1 mt-2">
            @foreach (var item in _searchCriteria.Components)
            {
                <MudChip T="string" Size="Size.Small"
                         Color="@(item.IsExcluded ? Color.Error : Color.Success)"
                         Icon="@(item.IsExcluded ? Icons.Material.Filled.Block : Icons.Material.Filled.Check)"
                         OnClick="@(() => ToggleComponent(item))" OnClose="@(() => RemoveComponent(item))">
                    @item.Value
                </MudChip>
            }
        </div>
    </MudItem>

            @* LABELS (Autocomplete) *@
            <MudItem xs="12" sm="6" md="4">
                <MudAutocomplete T="string" Label="Cerca e aggiungi Label"
                                 Value="@_labelSearchInput" ValueChanged="OnLabelAdded" SearchFunc="SearchLabelsAsync"
                                 Variant="Variant.Outlined" Dense="true" Clearable="true" MinCharacters="1" DebounceInterval="250"
                                 ResetValueOnEmptyText="true" Disabled="@_isLoading" />
                <div class="d-flex flex-wrap gap-1 mt-2">
                    @foreach (var item in _searchCriteria.Labels)
                    {
                        <MudChip T="string" Size="Size.Small" 
                                 Color="@(item.IsExcluded ? Color.Error : Color.Success)"
                                 Icon="@(item.IsExcluded ? Icons.Material.Filled.Block : Icons.Material.Filled.Check)"
                                 OnClick="@(() => ToggleLabel(item))" OnClose="@(() => RemoveLabel(item))">
                            @item.Value
                        </MudChip>
                    }
                </div>
            </MudItem>

            @if (ShowAssigneeFilter)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudSelect T="string" Label="Assignees" MultiSelection="true"
                               SelectedValues="_searchCriteria.Assignees.Select(x => x.Value).ToList()"
                               SelectedValuesChanged="OnAssigneesChanged"
                               Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter" Clearable="true" Dense="true"
                               MultiSelectionTextFunc="@(selected => selected is not null && selected.Count > 0 ? $"{selected.Count} selezionati" : string.Empty)"
                               Disabled="@_isLoading">
                        @foreach (var assignee in _assignees) { <MudSelectItem T="string" Value="@assignee.EmailAddress">@assignee.DisplayName</MudSelectItem> }
                    </MudSelect>
                    <div class="d-flex flex-wrap gap-1 mt-2">
                        @foreach (var item in _searchCriteria.Assignees)
                        {
                            <MudChip T="string" Size="Size.Small" 
                                     Color="@(item.IsExcluded ? Color.Error : Color.Success)"
                                     Icon="@(item.IsExcluded ? Icons.Material.Filled.Block : Icons.Material.Filled.Check)"
                                     OnClick="@(() => ToggleAssignee(item))" OnClose="@(() => RemoveAssignee(item))">
                                @(_assignees.FirstOrDefault(a => a.EmailAddress == item.Value)?.DisplayName ?? item.Value)
                            </MudChip>
                        }
                    </div>
                </MudItem>

                <MudItem xs="12" sm="6" md="4" Class="d-flex align-center">
                    <MudSwitch T="bool" Label="Includi non assegnate" Color="Color.Primary"
                               Value="_searchCriteria.IncludeUnassigned" ValueChanged="OnUnassignedChanged" Disabled="@_isLoading"/>
                </MudItem>
            }
            
            <MudItem xs="12" Class="pt-2">
                @if (_isLoading)
                {
                    <MudProgressLinear Color="Color.Secondary" Indeterminate="true" Class="mb-4" />
                }
                else if (!string.IsNullOrWhiteSpace(_searchCriteria.ProjectKey))
                {
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary); font-family: monospace;">
                        JQL: @_searchCriteria.ToJql()
                    </MudText>
                }
            </MudItem>
        </MudGrid>