<MudExpansionPanels Class="mb-4 mud-width-full" Elevation="2">
    <MudExpansionPanel Text="Filtri di Ricerca" Icon="@Icons.Material.Outlined.Flip" Expanded="true">
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudSelect T="string"
                           Label="Projects"
                           Value="_searchCriteria.ProjectKey"
                           ValueChanged="OnProjectChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Required="true"
                           RequiredError="Il progetto è obbligatorio">
                    @* ECCO LA VIRTUALIZZAZIONE MUDBLAZOR *@
                    <MudVirtualize ItemsProvider="LoadProjects" Context="project" OverscanCount="10" ItemSize="40">
                        <MudSelectItem T="string" Value="@project.Key">
                            @project.Key
                        </MudSelectItem>
                    </MudVirtualize>
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6" md="4">
                <MudSelect T="string"
                           Label="Statuses"
                           MultiSelection="true"
                           SelectedValues="_searchCriteria.Statuses"
                           SelectedValuesChanged="OnStatusesChanged"
                           Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter"
                           Clearable="true"
                           Dense="true"
                           MultiSelectionTextFunc="@(selected => GetSelectedStatusesText(selected))">
                    @foreach (var status in _statuses)
                    {
                        <MudSelectItem T="string" Value="@status.Name">@status.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6" md="4">
                <MudSelect T="string"
                           Label="Types"
                           MultiSelection="true"
                           SelectedValues="_searchCriteria.Types"
                           SelectedValuesChanged="OnTypesChanged"
                           Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter"
                           Clearable="true"
                           Dense="true"
                           MultiSelectionTextFunc="@(selected => GetSelectedTypesText(selected))">
                    @foreach (var type in _types)
                    {
                        <MudSelectItem T="string" Value="@type.Value">@type.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6" md="4">
                <MudSelect T="string"
                           Label="Components"
                           MultiSelection="true"
                           SelectedValues="_searchCriteria.Components"
                           SelectedValuesChanged="OnComponentsChanged"
                           Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter"
                           Clearable="true"
                           Dense="true"
                           MultiSelectionTextFunc="@(selected => GetSelectedComponentsText(selected))">
                    @foreach (var component in _components)
                    {
                        <MudSelectItem T="string" Value="@component.Value">@component.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6" md="4">
                <MudSelect T="string"
                           Label="Labels"
                           MultiSelection="true"
                           SelectedValues="_searchCriteria.Labels"
                           SelectedValuesChanged="OnLabelsChanged"
                           Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter"
                           Clearable="true"
                           Dense="true"
                           MultiSelectionTextFunc="@(selected => GetSelectedLabelsText(selected))">
                    @* ECCO LA VIRTUALIZZAZIONE MUDBLAZOR *@
                    <MudVirtualize ItemsProvider="LoadLabels" Context="label" OverscanCount="10" ItemSize="40">
                        <MudSelectItem T="string" Value="@label.Name">@label.Name</MudSelectItem>
                    </MudVirtualize>
                </MudSelect>
            </MudItem>

            @if (ShowAssigneeFilter)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudSelect T="string"
                               Label="Assignees"
                               MultiSelection="true"
                               SelectedValues="_searchCriteria.Assignees"
                               SelectedValuesChanged="OnAssigneesChanged"
                               Variant="Variant.Outlined"
                               AnchorOrigin="Origin.BottomCenter"
                               Clearable="true"
                               Dense="true"
                               MultiSelectionTextFunc="@(selected => GetSelectedAssigneesText(selected))">
                        @foreach (var assignee in _assignees)
                        {
                            <MudSelectItem T="string"
                                           Value="@assignee.EmailAddress">@assignee.DisplayName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6" md="4" Class="d-flex align-center">
                    <MudSwitch T="bool"
                               Label="Includi non assegnate"
                               Color="Color.Primary"
                               Value="_searchCriteria.IncludeUnassigned"
                               ValueChanged="OnUnassignedChanged"/>
                </MudItem>
            }
        </MudGrid>
    </MudExpansionPanel>
</MudExpansionPanels>