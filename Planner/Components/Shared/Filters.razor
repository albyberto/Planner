@using Planner.Builders
<MudExpansionPanels Class="mb-4 mud-width-full" Elevation="2">
    <MudExpansionPanel Text="Filtri di Ricerca" Icon="@Icons.Material.Outlined.Flip" Expanded="true">
        
        @if (_isLoading)
        {
            <MudProgressLinear Color="Color.Secondary" Indeterminate="true" Class="mb-4" />
        }

        <MudGrid>
            <MudItem xs="12" md="4">
                <MudAutocomplete T="string"
                                 Label="Projects"
                                 Value="_searchCriteria.ProjectKey"
                                 ValueChanged="OnProjectChangedAsync"
                                 SearchFunc="SearchProjectsAsync"
                                 Variant="Variant.Outlined"
                                 Dense="true"
                                 Required="true"
                                 RequiredError="Il progetto è obbligatorio"
                                 MinCharacters="1"
                                 DebounceInterval="250"
                                 ResetValueOnEmptyText="true" 
                                 Disabled="@_isLoading" />
            </MudItem>

            <MudItem xs="12" sm="6" md="4">
                <MudSelect T="string"
                           Label="Statuses"
                           MultiSelection="true"
                           SelectedValues="_searchCriteria.Statuses"
                           SelectedValuesChanged="OnStatusesChanged"
                           Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter"
                           Clearable="true"
                           Dense="true"
                           MultiSelectionTextFunc="@(selected => GetSelectedStatusesText(selected))"
                           Disabled="@_isLoading">
                    @foreach (var status in _statuses)
                    {
                        <MudSelectItem T="string" Value="@status.Name">@status.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6" md="4">
                <MudSelect T="string"
                           Label="Types"
                           MultiSelection="true"
                           SelectedValues="_searchCriteria.Types"
                           SelectedValuesChanged="OnTypesChanged"
                           Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter"
                           Clearable="true"
                           Dense="true"
                           MultiSelectionTextFunc="@(selected => GetSelectedTypesText(selected))"
                           Disabled="@_isLoading">
                    @foreach (var type in _types)
                    {
                        <MudSelectItem T="string" Value="@type.Value">@type.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6" md="4">
                <MudSelect T="string"
                           Label="Components"
                           MultiSelection="true"
                           SelectedValues="_searchCriteria.Components"
                           SelectedValuesChanged="OnComponentsChanged"
                           Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter"
                           Clearable="true"
                           Dense="true"
                           MultiSelectionTextFunc="@(selected => GetSelectedComponentsText(selected))"
                           Disabled="@_isLoading">
                    @foreach (var component in _components)
                    {
                        <MudSelectItem T="string" Value="@component.Value">@component.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6" md="4">
                <MudAutocomplete T="string"
                                 Label="Cerca e aggiungi Label"
                                 Value="@_labelSearchInput"
                                 ValueChanged="OnLabelAdded"
                                 SearchFunc="SearchLabelsAsync"
                                 Variant="Variant.Outlined"
                                 Dense="true"
                                 Clearable="true"
                                 MinCharacters="1"
                                 DebounceInterval="250"
                                 ResetValueOnEmptyText="true"
                                 Disabled="@_isLoading" />

                @if (_searchCriteria.Labels.Any())
                {
                    <div class="d-flex flex-wrap gap-1 mt-2">
                        @foreach (var label in _searchCriteria.Labels)
                        {
                            <MudChip T="string" 
                                     Color="Color.Info" 
                                     Size="Size.Small" 
                                     OnClose="@(() => RemoveLabel(label))">
                                @label
                            </MudChip>
                        }
                    </div>
                }
            </MudItem>

            @if (ShowAssigneeFilter)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudSelect T="string"
                               Label="Assignees"
                               MultiSelection="true"
                               SelectedValues="_searchCriteria.Assignees"
                               SelectedValuesChanged="OnAssigneesChanged"
                               Variant="Variant.Outlined"
                               AnchorOrigin="Origin.BottomCenter"
                               Clearable="true"
                               Dense="true"
                               MultiSelectionTextFunc="@(selected => GetSelectedAssigneesText(selected))"
                               Disabled="@_isLoading">
                        @foreach (var assignee in _assignees)
                        {
                            <MudSelectItem T="string"
                                           Value="@assignee.EmailAddress">@assignee.DisplayName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6" md="4" Class="d-flex align-center">
                    <MudSwitch T="bool"
                               Label="Includi non assegnate"
                               Color="Color.Primary"
                               Value="_searchCriteria.IncludeUnassigned"
                               ValueChanged="OnUnassignedChanged"
                               Disabled="@_isLoading"/>
                </MudItem>
            }
            
            <MudItem xs="12" Class="pt-2">
                @if (!string.IsNullOrWhiteSpace(_searchCriteria.ProjectKey))
                {
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary); font-family: monospace;">
                        JQL: @_searchCriteria.ToJql()
                    </MudText>
                }
            </MudItem>
            
        </MudGrid>
    </MudExpansionPanel>
</MudExpansionPanels>