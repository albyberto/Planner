@using Planner.Model.Abstract
@typeparam TItem where TItem : IAvatar

<div class="d-flex align-center" style="gap: 8px;">
    <MudAvatar 
               Color="@Color"
               Variant="Variant.Outlined"
               Rounded="@Rounded"
               Square="@Square"
               Size="@Size">
        @if (string.IsNullOrWhiteSpace(GetImageUrl()) && !string.IsNullOrWhiteSpace(Name))
        {
            @GetInitials()
        }
        else
        {
            <MudImage Src="@GetImageUrl()" Alt="@($"{Name} Project Icon")"></MudImage>
        }
    </MudAvatar>

    @if (ShowText)
    {
        <MudText Typo="Typo.body2" Class="fw-500 mud-text-secondary mb-0" Style="line-height: 1;">
            @Name
        </MudText>
    }
</div>

@code {
    [Parameter, EditorRequired] public required TItem Item { get; set; }

    [Parameter] public int SizePx { get; set; } = 16;
    [Parameter] public Color Color { get; set; } = Color.Transparent;
    
    [Parameter] public bool Rounded { get; set; }
    [Parameter] public bool Square { get; set; }

    [Parameter] public bool ShowText { get; set; } = true;
    
    private string Name => $"{Item}".Trim();
    
    private Size Size =>
        SizePx switch
        {
            <= 16 => Size.Small,
            <= 24 => Size.Medium,
            <= 32 => Size.Large,
            _ => Size.Medium
        };

    private string? GetImageUrl()
    {
        if (Item.Avatars is null) return null;
        
        return SizePx switch
        {
            <= 16 => Item.Avatars._16x16,
            <= 24 => Item.Avatars._24x24,
            <= 32 => Item.Avatars._32x32,
            _ => Item.Avatars._48x48
        };
    }

    private string GetInitials() => string.IsNullOrWhiteSpace(Name) 
        ? string.Empty 
        : string.Concat(Name.Take(2)).ToUpper();
}