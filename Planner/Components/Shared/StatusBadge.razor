@using Planner.Domain
<MudChip T="string" Size="Size.Small" Color="@Style.Color" Icon="@Style.Icon" Variant="Variant.Filled">
    @Status.Name
</MudChip>

@code {
    [Parameter][EditorRequired] public required Status Status { get; set; } = null!;

    private (Color Color, string Icon) Style => Status.StatusCategory.Name switch
    {
        "To Do" => (Color.Default, Icons.Material.Filled.RadioButtonUnchecked),
        "In Progress" => (Color.Info, Icons.Material.Filled.Autorenew),
        "Done" => (Color.Success, Icons.Material.Filled.CheckCircle),
        _ => (Color.Default, Icons.Material.Filled.Circle)
    };
}