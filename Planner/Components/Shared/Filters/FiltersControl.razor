@using Planner.Builders
@using Planner.Components.Shared.Filters.Model
@using System.Collections.Immutable;
@using Microsoft.Extensions.Options;
@using Planner.Components.Shared.Filters.Controls
@using Planner.Model;
@using Planner.Options;
@using Planner.Services;
@using Planner.Stores;

<MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4 position-relative overflow-hidden">
    
    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Secondary" Indeterminate="true" Size="Size.Small" Class="position-absolute" Style="top: 0; left: 0; right: 0; z-index: 10;" />
    }

    <MudGrid>
        <MudItem xs="12" md="4">
            <MudAutocomplete T="string" Label="Progetto Jira"
                             Value="_searchCriteria.ProjectKey" ValueChanged="OnProjectChangedAsync"
                             SearchFunc="SearchProjectsAsync" Variant="Variant.Outlined" Dense="true"
                             Required="true" RequiredError="Il progetto è obbligatorio"
                             MinCharacters="1" DebounceInterval="250" ResetValueOnEmptyText="true" Disabled="@_isLoading" />
        </MudItem>

        <MudItem xs="12" md="8">
            <FilterSearchControl 
                TItem="ComponentModel" 
                Label="Cerca Componente" 
                Items="_components.ToImmutableHashSet()"
                Selection="_searchCriteria.Components"
                SelectionChanged="OnComponentsChanged"
                Disabled="@_isLoading"/>
        </MudItem>

        <MudItem xs="12" Class="d-flex justify-end pt-2">
            @if (!_isLoading && !string.IsNullOrWhiteSpace(_searchCriteria.ProjectKey))
            {
                <MudText Typo="Typo.caption">
                    @* @_searchCriteria.ToJql() *@
                </MudText>
            }
        </MudItem>
    </MudGrid>
</MudPaper>

@code {
    [Inject] public required IOptions<JiraFilterOptions> Options { get; set; }
    [Inject] public required ProjectsService ProjectsService { get; set; }
    [Inject] public required FilterStore FilterStore { get; set; }
    [Inject] public required ISnackbar Snackbar { get; set; }

    [Parameter] public Guid PageKey { get; set; }
        
    private ImmutableArray<ProjectModel> _projects = [];
    private ImmutableArray<ComponentModel> _components = [];

    private IssuesSearchCriteria _searchCriteria = IssuesSearchCriteria.Empty;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _isLoading = true;
            
            var options = Options.Value;
            _searchCriteria = IssuesSearchCriteria.Create(options.DefaultProject);

            FilterStore.Register(PageKey);
            Emit(_searchCriteria);

            await BuildAsync(options.DefaultProject);
        }
        catch(Exception)
        {
            Snackbar.Add("Errore durante l'inizializzazione dei filtri.", Severity.Error);
        }
        finally
        {
            _isLoading = false; 
        }
    }

    private Task<IEnumerable<string>> SearchProjectsAsync(string? value, CancellationToken cancellationToken)
    {
        if (string.IsNullOrWhiteSpace(value)) return Task.FromResult<IEnumerable<string>>([]);
        var token = value.Trim().ToUpperInvariant();
        return Task.FromResult(_projects.Where(p => p.Key.StartsWith(token, StringComparison.OrdinalIgnoreCase)).Select(p => p.Key));
    }

    private async Task OnProjectChangedAsync(string? projectKey)
    {
        if (string.IsNullOrWhiteSpace(projectKey)) return;

        var token = projectKey.Trim().ToUpperInvariant();
        if (!_projects.Select(project => project.Key).Contains(projectKey, StringComparer.OrdinalIgnoreCase)) return;
        
        try
        {
            _isLoading = true;
            _searchCriteria = IssuesSearchCriteria.Create(projectKey); // Resetta implicitamente anche i components
            Emit(_searchCriteria);
            await BuildAsync(projectKey);
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ECCO LA TUA LOGICA PULITA: Riceve l'interfaccia ed emette il nuovo stato. Fine.
    private void OnComponentsChanged(IFilterSelection<ComponentModel> newSelection)
    {
        _searchCriteria = _searchCriteria with { Components = newSelection };
        Emit(_searchCriteria);
    }

    private void Emit(IssuesSearchCriteria criteria) => FilterStore.Emit(PageKey, criteria);

    private async Task BuildAsync(string projectKey)
    {
        var projectsTask = ProjectsService.GetProjectsAsync(CancellationToken.None);
        var componentsTask = ProjectsService.GetComponentsAsync(projectKey);

        await Task.WhenAll(projectsTask, componentsTask);

        _projects = projectsTask.Result;
        _components = componentsTask.Result;
    }

    public void Dispose() => FilterStore.UnRegister(PageKey);
}