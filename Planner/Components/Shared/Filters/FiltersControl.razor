@using System.Collections.Immutable
@using Microsoft.Extensions.Options
@using Planner.Builders
@using Planner.Components.Shared.Filters.Controls
@using Planner.Components.Shared.Filters.Model
@using Planner.Model
@using Planner.Options
@using Planner.Services
@using Planner.Stores
<MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4 position-relative overflow-hidden">

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Secondary" Indeterminate="true" Size="Size.Small"/>
    }

    <MudGrid>
        <MudItem xs="12" sm="12" md="4" lg="4">
            <FilterSingleAutocomplete TItem="ProjectModel"
                                      Label="Project Key"
                                      Disabled="@_isLoading"
                                      Items="_projects"
                                      SelectedValue="_searchCriteria.Project"
                                      SelectedValueChanged="OnProjectChangedAsync"
                                      Required="true">
                <Avatar Item="@context"/>
            </FilterSingleAutocomplete>
        </MudItem>

        <MudItem xs="12" sm="12" md="4" lg="4">
            <FilterMultiSelect TItem="TypeModel"
                               Label="Select Types"
                               Disabled="_isLoading"
                               Items="_types"
                               Selection="_searchCriteria.Types"
                               SelectionChanged="OnTypesChangedAsync"/>
        </MudItem>

        <MudItem xs="12" sm="12" md="4" lg="4">
            <FilterMultiSelect TItem="StatusModel"
                               Label="Select Statuses"
                               Disabled="_isLoading"
                               Items="_statuses"
                               Selection="_searchCriteria.Statuses"
                               SelectionChanged="OnStatusesChanged"/>
        </MudItem>

        <MudItem xs="12" sm="12" md="4" lg="4">
            <FilterMultiSelect TItem="ComponentModel"
                               Label="Select Components"
                               Disabled="_isLoading"
                               Items="_components"
                               Selection="_searchCriteria.Components"
                               SelectionChanged="OnComponentsChanged"/>
        </MudItem>

        <MudItem xs="12" sm="12" md="4" lg="4">
            <FilterAutocomplete TItem="LabelModel"
                                Label="Search Labels"
                                Disabled="_isLoading"
                                Items="_labels"
                                Selection="_searchCriteria.Labels"
                                SelectionChanged="OnLabelsChanged"/>
        </MudItem>

        <MudItem xs="12" sm="12" md="4" lg="4">
            <FilterDateControl
                Label="Data Creazione"
                Value="@(GetDateFilter("created"))"
                ValueChanged="@(v => SetDateFilter("created", v))"
                Disabled="_isLoading"/>
        </MudItem>

        <MudItem xs="12" sm="12" md="4" lg="4">
            <FilterDateControl
                Label="Data Risoluzione"
                Value="@(GetDateFilter("resolved"))"
                ValueChanged="@(v => SetDateFilter("resolved", v))"
                Disabled="_isLoading"/>
        </MudItem>

        <MudItem xs="12" sm="12" md="4" lg="4">
            <FilterDateControl
                Label="Due Date"
                Value="@(GetDateFilter("duedate"))"
                ValueChanged="@(v => SetDateFilter("duedate", v))"
                Disabled="_isLoading"/>
        </MudItem>

        <MudItem xs="12" sm="12" md="4" lg="4">
            <FilterTransition TItem="StatusModel"
                              Items="_statuses"
                              Value="@(GetStatusTransition("status"))"
                              ValueChanged="OnStatusTransitionChanged"
                              LeftColumnHeader="Status..."
                              RightColumnHeader="Period..."
                              Label="Passaggio di Stato"
                              Disabled="_isLoading"/>
        </MudItem>

        <MudItem xs="12" sm="12" md="4" lg="4" Class="d-flex justify-end pt-2">
            @if (!_isLoading)
            {
                <MudText Typo="Typo.caption">
                    @_searchCriteria.ToJql()
                </MudText>
            }
        </MudItem>
    </MudGrid>

</MudPaper>

@code {
    [Inject] public required IOptions<JiraFilterOptions> Options { get; set; }
    [Inject] public required FilterService FilterService { get; set; }
    [Inject] public required FilterStore FilterStore { get; set; }
    [Inject] public required ISnackbar Snackbar { get; set; }

    [Parameter] public Guid PageKey { get; set; }

    private ImmutableArray<ProjectModel> _projects = [];
    private ImmutableArray<TypeModel> _types = [];
    private ImmutableArray<StatusModel> _statuses = [];
    private ImmutableArray<ComponentModel> _components = [];
    private ImmutableArray<LabelModel> _labels = [];

    private IssuesSearchCriteria _searchCriteria = IssuesSearchCriteria.Empty;
    private bool _isLoading = true;

    private DatePreset.Preset GetDateFilter(string field) =>
        _searchCriteria.DateFilters.TryGetValue(field, out var preset) ? preset : DatePreset.Preset.None;

    private void SetDateFilter(string field, DatePreset.Preset preset)
    {
        _searchCriteria = _searchCriteria.SetDateFilter(field, preset);
        Emit(_searchCriteria);
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _isLoading = true;

            FilterStore.Register(PageKey);
            Emit(_searchCriteria);

            await BuildAsync(Options.Value.DefaultProject);
        }
        catch (Exception)
        {
            Snackbar.Add("Errore durante l'inizializzazione dei filtri.", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnProjectChangedAsync(ProjectModel? project)
    {
        if (project is null || !_projects.Any(p => string.Equals(p.Key, project.Key, StringComparison.OrdinalIgnoreCase)))
        {
            return;
        }

        try
        {
            _isLoading = true;

            Emit(_searchCriteria);
            await BuildAsync(project.Key);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnTypesChangedAsync(IFilterSelection<TypeModel> types)
    {
        _searchCriteria = _searchCriteria with { Types = types };

        try
        {
            _isLoading = true;
            var projectKey = _searchCriteria.Project?.Key ?? Options.Value.DefaultProject;
            _statuses = await FilterService.GetStatusesAsync(projectKey, _searchCriteria.Types.Items);
        }
        finally
        {
            _isLoading = false;
            Emit(_searchCriteria);
        }
    }

    private void OnStatusesChanged(IFilterSelection<StatusModel> statuses)
    {
        _searchCriteria = _searchCriteria with { Statuses = statuses };
        Emit(_searchCriteria);
    }

    private void OnComponentsChanged(IFilterSelection<ComponentModel> components)
    {
        _searchCriteria = _searchCriteria with { Components = components };
        Emit(_searchCriteria);
    }

    private void OnLabelsChanged(IFilterSelection<LabelModel> labels)
    {
        _searchCriteria = _searchCriteria with { Labels = labels };
        Emit(_searchCriteria);
    }

    private TransitionFilter<StatusModel> GetStatusTransition(string field)
    {
        if (!_searchCriteria.TransitionFilters.TryGetValue(field, out var filter)) return new();

        var statusModel = _statuses.FirstOrDefault(s => string.Equals(s.Name, filter.Item, StringComparison.OrdinalIgnoreCase));

        return new(statusModel, filter.Preset);
    }

    private void OnStatusTransitionChanged(TransitionFilter<StatusModel> transition)
    {
        var stringFilter = new TransitionFilter<string>(transition.Item?.Name, transition.Preset);

        _searchCriteria = _searchCriteria.SetTransitionFilter("status", stringFilter);
        Emit(_searchCriteria);
    }

    private void Emit(IssuesSearchCriteria criteria) => FilterStore.Emit(PageKey, criteria);

    private async Task BuildAsync(string projectKey)
    {
        var projectsTask = FilterService.GetProjectsAsync(CancellationToken.None);
        var typesTask = FilterService.GetTypesAsync(projectKey);
        var componentsTask = FilterService.GetComponentsAsync(projectKey);
        var labelsTask = FilterService.GetLabelsAsync();

        await Task.WhenAll(projectsTask, typesTask, componentsTask, labelsTask);

        _projects = projectsTask.Result;
        _types = typesTask.Result;
        _components = componentsTask.Result;
        _labels = labelsTask.Result;

        _statuses = await FilterService.GetStatusesAsync(projectKey, _searchCriteria.Types.Items);

        var project = _projects.Single(project => project.Key.Equals(projectKey, StringComparison.OrdinalIgnoreCase));
        _searchCriteria = IssuesSearchCriteria.Create(project);
        
    }

    public void Dispose() => FilterStore.UnRegister(PageKey);
}