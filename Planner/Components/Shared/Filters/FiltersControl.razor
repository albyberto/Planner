@using System.Collections.Immutable
@using Microsoft.Extensions.Options
@using Planner.Builders
@using Planner.Components.Shared.Filters.Controls
@using Planner.Components.Shared.Filters.Model
@using Planner.Facades
@using Planner.Infrastructure.Core.Abstract
@using Planner.Infrastructure.Domain
@using Planner.Infrastructure.Domain.Enums
@using Planner.Mappers
@using Planner.Model
@using Planner.Options
<MudPaper Elevation="0" Outlined="true" Class="pa-4 mb-4 position-relative overflow-hidden">

    @if (_isLoading) {
        <MudProgressLinear Color="Color.Secondary" Indeterminate="true" Size="Size.Small"/>
    }

    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween"
              Class="@(_isExpanded ? "mb-4" : "")">

        <MudText Typo="Typo.h6" Class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.FilterAlt" Size="Size.Small"/>
            Search Filters
        </MudText>

        @if (Collapsable) {
            <MudIconButton Icon="@(_isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                           OnClick="@(() => _isExpanded = !_isExpanded)"
                           Size="Size.Medium"
                           Color="Color.Default"/>
        }
    </MudStack>

    <MudCollapse Expanded="@(!Collapsable || _isExpanded)">
        <MudGrid>
            @* Visualizziamo il selettore dei preset solo se non ne è stato imposto uno dall'esterno (Dashboard) *@
            @if (InitialPreset is null) {
                <MudItem xs="12">
                    <FilterSingleAutocomplete TItem="PresetItem"
                                              Label="Load Preset"
                                              Disabled="@_isLoading"
                                              Items="_presets"
                                              SelectedValue="_selectedPreset"
                                              SelectedValueChanged="OnPresetChangedAsync"
                                              Clearable="true"
                                              Required="false"/>
                </MudItem>
            }

            <MudItem xs="12" sm="12" md="4" lg="4">
                <FilterSingleAutocomplete TItem="ProjectModel"
                                          Label="Project Key"
                                          Disabled="@(IsControlDisabled || LockedProjectKey is not null)"
                                          Items="_projects"
                                          SelectedValue="_searchCriteria.Project"
                                          SelectedValueChanged="OnProjectChangedAsync"
                                          Required="true"/>
            </MudItem>

            <MudItem xs="12" sm="12" md="4" lg="4">
                <FilterMultiSelect TItem="TypeModel"
                                   Label="Select Types"
                                   Disabled="@IsControlDisabled"
                                   Items="_types"
                                   Selection="_searchCriteria.Types"
                                   SelectionChanged="OnTypesChangedAsync"
                                   Square="@true"/>
            </MudItem>

            <MudItem xs="12" sm="12" md="4" lg="4">
                <FilterMultiSelect TItem="StatusModel"
                                   Label="Select Statuses"
                                   Disabled="@IsControlDisabled"
                                   Items="_statuses"
                                   Selection="_searchCriteria.Statuses"
                                   SelectionChanged="OnStatusesChanged"/>
            </MudItem>

            <MudItem xs="12" sm="12" md="4" lg="4">
                <div class="d-flex flex-column gap-1">
                    <FilterMultiSelect TItem="UserModel"
                                       Label="Select Assignees"
                                       Disabled="@(IsControlDisabled || LockedEmail is not null)"
                                       Items="_assignees"
                                       Selection="_searchCriteria.Assignees"
                                       SelectionChanged="OnAssigneesChanged"/>

                    <MudSwitch T="bool"
                               Label="Include unassigned"
                               Color="Color.Primary"
                               Size="Size.Medium"
                               Disabled="@(IsControlDisabled || LockedEmail is not null)"
                               Value="_searchCriteria.IncludeUnassigned"
                               ValueChanged="OnIncludeUnassignedChanged"
                               Class="ml-1"/>
                </div>
            </MudItem>

            <MudItem xs="12" sm="12" md="4" lg="4">
                <FilterMultiSelect TItem="ComponentModel"
                                   Label="Select Components"
                                   Disabled="@IsControlDisabled"
                                   Items="_components"
                                   Selection="_searchCriteria.Components"
                                   SelectionChanged="OnComponentsChanged"/>
            </MudItem>

            <MudItem xs="12" sm="12" md="4" lg="4">
                <FilterAutocomplete TItem="LabelModel"
                                    Label="Search Labels"
                                    Disabled="@IsControlDisabled"
                                    Items="_labels"
                                    Selection="_searchCriteria.Labels"
                                    SelectionChanged="OnLabelsChanged"/>
            </MudItem>

            <MudItem xs="12" sm="12" md="4" lg="4">
                <FilterDate Label="Data Creazione" Value="@(GetDateFilter("created"))"
                            ValueChanged="@(v => SetDateFilter("created", v))" Disabled="@IsControlDisabled"/>
            </MudItem>

            <MudItem xs="12" sm="12" md="4" lg="4">
                <FilterDate Label="Data Risoluzione" Value="@(GetDateFilter("resolved"))"
                            ValueChanged="@(v => SetDateFilter("resolved", v))" Disabled="@IsControlDisabled"/>
            </MudItem>

            <MudItem xs="12" sm="12" md="4" lg="4">
                <FilterDate Label="Start Date" Value="@(GetDateFilter("Start date"))"
                            ValueChanged="@(v => SetDateFilter("Start date", v))" Disabled="@IsControlDisabled"/>
            </MudItem>
            <MudItem xs="12" sm="12" md="4" lg="4">
                <FilterDate Label="End Date" Value="@(GetDateFilter("End date"))"
                            ValueChanged="@(v => SetDateFilter("End date", v))" Disabled="@IsControlDisabled"/>
            </MudItem>
            <MudItem xs="12" sm="12" md="4" lg="4">
                <FilterDate Label="Due Date" Value="@(GetDateFilter("duedate"))"
                            ValueChanged="@(v => SetDateFilter("duedate", v))" Disabled="@IsControlDisabled"/>
            </MudItem>

            <MudItem xs="12" sm="12" md="4" lg="4">
                <FilterTransition TItem="StatusModel"
                                  Items="_statuses"
                                  Value="_searchCriteria.StatusTransition"
                                  ValueChanged="OnStatusTransitionChanged"
                                  LeftColumnHeader="Status..."
                                  RightColumnHeader="Period..."
                                  Label="Passaggio di Stato"
                                  Disabled="@IsControlDisabled"/>
            </MudItem>

            <MudItem xs="12" Class="d-flex justify-end pt-2">
                @if (!_isLoading) {
                    <MudText Typo="Typo.caption">@_searchCriteria.ToJql()</MudText>
                }
            </MudItem>
        </MudGrid>
    </MudCollapse>
</MudPaper>

@code {
    [Inject] public required IOptions<JiraFilterOptions> Options { get; set; }
    [Inject] public required ProjectFacade ProjectFacade { get; set; }
    [Inject] public required IPresetService PresetService { get; set; }
    [Inject] public required ISnackbar Snackbar { get; set; }

    [Parameter] public bool Collapsable { get; set; } = true;
    [Parameter] public required EventCallback<SearchCriteria> OnCriteriaChanged { get; set; }

    [Parameter] public PresetItem? InitialPreset { get; set; }
    [Parameter] public string? LockedProjectKey { get; set; }
    [Parameter] public string? LockedEmail { get; set; }

    private ImmutableArray<ProjectModel> _projects = [];
    private ImmutableArray<TypeModel> _types = [];
    private ImmutableArray<StatusModel> _statuses = [];
    private ImmutableArray<UserModel> _assignees = [];
    private ImmutableArray<ComponentModel> _components = [];
    private ImmutableArray<LabelModel> _labels = [];
    private ImmutableArray<PresetItem> _allPresets = [];
    private ImmutableArray<PresetItem> _presets = [];

    private PresetItem? _selectedPreset;
    private SearchCriteria _searchCriteria = SearchCriteria.Empty;
    private bool _isLoading = true;
    private bool _isExpanded = true;

    private bool IsControlDisabled => _isLoading || (_selectedPreset is not null && InitialPreset is null);

    protected override async Task OnInitializedAsync() {
        try {
            _isLoading = true;

            if (InitialPreset is not null) {
                _selectedPreset = InitialPreset;
            } else {
                _allPresets = await PresetService.GetAllAsync();
                
                if (LockedProjectKey is not null) {
                    _presets = [.._allPresets.Where(p => string.Equals(p.Criteria.ProjectKey, LockedProjectKey, StringComparison.OrdinalIgnoreCase))];
                } else {
                    _presets = _allPresets;
                }
                
                _selectedPreset = await PresetService.GetDefaultAsync();
                if (LockedProjectKey is not null && (_selectedPreset is null || !string.Equals(_selectedPreset.Criteria.ProjectKey, LockedProjectKey, StringComparison.OrdinalIgnoreCase))) {
                    _selectedPreset = _presets.FirstOrDefault();
                }
            }

            var projectKey = LockedProjectKey ?? _selectedPreset?.Criteria.ProjectKey ?? Options.Value.DefaultProject;
            await BuildAsync(projectKey);
        }
        catch (Exception) {
            Snackbar.Add("Errore durante l'inizializzazione dei filtri.", Severity.Error);
        }
        finally {
            _isLoading = false;
        }
    }

    private async Task OnPresetChangedAsync(PresetItem? preset) {
        _selectedPreset = preset;
        _isLoading = true;
        try {
            var projectKey = LockedProjectKey ?? preset?.Criteria.ProjectKey ?? Options.Value.DefaultProject;
            await BuildAsync(projectKey);
            await OnCriteriaChanged.InvokeAsync(_searchCriteria);
        }
        finally {
            _isLoading = false;
        }
    }

    private async Task OnProjectChangedAsync(ProjectModel? project) {
        if (project is null) return;
        _isLoading = true;
        try {
            await BuildAsync(project.Key);
            await OnCriteriaChanged.InvokeAsync(_searchCriteria);
        }
        finally {
            _isLoading = false;
        }
    }

    private async Task OnTypesChangedAsync(IFilterSelection<TypeModel> types) {
        _searchCriteria = _searchCriteria with { Types = types };
        _isLoading = true;
        try {
            var projectKey = _searchCriteria.Project?.Key ?? Options.Value.DefaultProject;
            _statuses = await ProjectFacade.GetStatusesAsync(projectKey, _searchCriteria.Types.Items);
            await OnCriteriaChanged.InvokeAsync(_searchCriteria);
        }
        finally {
            _isLoading = false;
        }
    }

    private async Task OnStatusesChanged(IFilterSelection<StatusModel> statuses) {
        _searchCriteria = _searchCriteria with { Statuses = statuses };
        await OnCriteriaChanged.InvokeAsync(_searchCriteria);
    }

    private async Task OnAssigneesChanged(IFilterSelection<UserModel> assignees) {
        _searchCriteria = _searchCriteria with { Assignees = assignees };
        await OnCriteriaChanged.InvokeAsync(_searchCriteria);
    }

    private async Task OnIncludeUnassignedChanged(bool newValue) {
        _searchCriteria = _searchCriteria with { IncludeUnassigned = newValue };
        await OnCriteriaChanged.InvokeAsync(_searchCriteria);
    }

    private async Task OnComponentsChanged(IFilterSelection<ComponentModel> components) {
        _searchCriteria = _searchCriteria with { Components = components };
        await OnCriteriaChanged.InvokeAsync(_searchCriteria);
    }

    private async Task OnLabelsChanged(IFilterSelection<LabelModel> labels) {
        _searchCriteria = _searchCriteria with { Labels = labels };
        await OnCriteriaChanged.InvokeAsync(_searchCriteria);
    }

    private Preset GetDateFilter(string field) => _searchCriteria.DateFilters.TryGetValue(field, out var preset) ? preset : Preset.None;

    private async Task SetDateFilter(string field, Preset preset) {
        _searchCriteria = _searchCriteria.SetDateFilter(field, preset);
        await OnCriteriaChanged.InvokeAsync(_searchCriteria);
    }

    private async Task OnStatusTransitionChanged(TransitionFilter<StatusModel> transition) {
        _searchCriteria = _searchCriteria.SetStatusTransition(transition);
        await OnCriteriaChanged.InvokeAsync(_searchCriteria);
    }

    private async Task BuildAsync(string projectKey) {
        if (string.IsNullOrEmpty(projectKey)) return;

        if (_projects.IsDefaultOrEmpty) {
            _projects = await ProjectFacade.GetProjectsAsync(CancellationToken.None);
        }

        var typesTask = ProjectFacade.GetTypesAsync(projectKey);
        var assigneesTask = ProjectFacade.GetAssigneesAsync(projectKey);
        var componentsTask = ProjectFacade.GetComponentsAsync(projectKey);
        var labelsTask = ProjectFacade.GetLabelsAsync();

        await Task.WhenAll(typesTask, assigneesTask, componentsTask, labelsTask);

        _types = await typesTask;
        _assignees = await assigneesTask;
        _components = await componentsTask;
        _labels = await labelsTask;

        var currentProject = _projects.FirstOrDefault(p => p.Key.Equals(projectKey, StringComparison.OrdinalIgnoreCase));

        if (currentProject is null) {
            Snackbar.Add($"Impossibile recuperare il progetto selezionato, provare a aggiornare la cache", Severity.Error);
            return;
        }
        
        if (_selectedPreset is not null) {
            _searchCriteria = _selectedPreset.ToModel(_projects, _types, _assignees, _components, _labels);
        
            if (_searchCriteria.Project?.Key != projectKey) {
                _searchCriteria = _searchCriteria with { Project = currentProject };
            }

            _statuses = await ProjectFacade.GetStatusesAsync(projectKey, _searchCriteria.Types.Items);
            _searchCriteria = _searchCriteria.HydrateStatuses(_selectedPreset, _statuses);
        } else {
            _searchCriteria = SearchCriteria.Create(currentProject);
            _statuses = await ProjectFacade.GetStatusesAsync(projectKey, _searchCriteria.Types.Items);
        }
        
        // Applica i lock se definiti
        if (LockedProjectKey is not null) {
             _searchCriteria = _searchCriteria with { Project = currentProject };
        }
        
        if (LockedEmail is not null) {
            if (LockedEmail.Equals(Constants.Unassigned, StringComparison.OrdinalIgnoreCase)) {
                _searchCriteria = _searchCriteria with { IncludeUnassigned = true, Assignees = FilterSelection<UserModel>.Empty };
            } else {
                var lockedUser = _assignees.FirstOrDefault(u => u.EmailAddress.Equals(LockedEmail, StringComparison.OrdinalIgnoreCase));
                var userSelection = lockedUser is not null ? FilterSelection<UserModel>.Empty.Add(lockedUser) : FilterSelection<UserModel>.Empty;
                _searchCriteria = _searchCriteria with { IncludeUnassigned = false, Assignees = userSelection };
            }
        }

        await OnCriteriaChanged.InvokeAsync(_searchCriteria);
    }
}