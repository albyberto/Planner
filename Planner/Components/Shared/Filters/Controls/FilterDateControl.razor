@using Planner.Components.Shared.Filters.Model

<MudSelect T="DatePreset.Preset" 
           Label="@Label"
           Value="@Value"
           ValueChanged="OnValueChangedAsync"
           Variant="Variant.Outlined" 
           Margin="Margin.Dense" 
           Disabled="@Disabled" 
           Clearable="true">
    @foreach (DatePreset.Preset preset in Enum.GetValues(typeof(DatePreset.Preset)))
    {
        <MudSelectItem T="DatePreset.Preset" Value="@preset">@($"{preset}")</MudSelectItem>
    }
</MudSelect>

@code {
    [Parameter] public string Label { get; set; } = "Periodo...";
    
    [Parameter] public DatePreset.Preset Value { get; set; } = DatePreset.Preset.None;
    [Parameter] public EventCallback<DatePreset.Preset> ValueChanged { get; set; }

    [Parameter] public bool Disabled { get; set; } = true;

    private Task OnValueChangedAsync(DatePreset.Preset preset) => ValueChanged.InvokeAsync(preset);
}