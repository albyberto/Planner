@using Planner.Components.Shared.Filters.Model
@using Planner.Extensions
@typeparam TItem

<div class="position-relative w-100">
    <MudTextField T="string"
                  Label="@Label"
                  Text="@GetDisplayValue()"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  ReadOnly="true"
                  Disabled="@Disabled"
                  Adornment="Adornment.End"
                  AdornmentIcon="@GetAdornmentIcon()"
                  OnAdornmentClick="HandleAdornmentClick"
                  @onclick="ToggleOpen"
                  Class="w-100 clickable-input transition-filter-input" />

    <MudPopover Open="@_isOpen"
                AnchorOrigin="Origin.BottomLeft"
                TransformOrigin="Origin.TopLeft"
                RelativeWidth="DropdownWidth.Relative"
                MaxHeight="400"
                Class="mud-elevation-2 rounded-lg overflow-hidden harmonized-popover">

        <div class="d-flex flex-row picker-layout">
            @* Colonna Sinistra: Stato *@
            <div class="flex-1 d-flex flex-column w-50 picker-border-right">
                <div class="pa-2 text-center picker-column-header">
                    <MudText Typo="Typo.caption" Color="Color.Dark" Class="fw-500">@LeftColumnHeader</MudText>
                </div>
                <div class="picker-scroll-container">
                    <div class="picker-item @(Value.Item is null ? "selected" : "")"
                         @onclick="@(() => OnItemClickedAsync(default))">
                        @NullItemLabel
                    </div>
                        @foreach (var item in Items)
                        {
                            var isSelected = EqualityComparer<TItem>.Default.Equals(Value.Item, item);
                            <div class="picker-item @(isSelected ? "selected" : "")"
                                 @onclick="@(() => OnItemClickedAsync(item))">
                                @($"{item}")
                            </div>
                        }
                </div>
            </div>

            @* Colonna Destra: Periodo *@
            <div class="flex-1 d-flex flex-column w-50">
                <div class="pa-2 text-center picker-column-header">
                    <MudText Typo="Typo.caption" Color="Color.Dark" Class="fw-500">Period</MudText>
                </div>
                <div class="picker-scroll-container">
                    @foreach (var option in DatePreset.Options)
                    {
                        var isSelected = Value?.Preset == option.Value;
            
                        var timelineClass = option.Category switch {
                            DatePreset.Category.Past => "timeline-past",
                            DatePreset.Category.Present => "timeline-present",
                            DatePreset.Category.Future => "timeline-future",
                            _ => "timeline-none"
                        };

                        <div class="picker-item @(isSelected ? "selected" : "") @timelineClass" @onclick="@(() => OnPresetClickedAsync(option.Value))">
                            @option.Value.ToTitleCase()
                        </div>
                    }
                </div>
            </div>
        </div>
    </MudPopover>

    @* L'overlay che chiude il popover cliccando fuori *@
    <MudOverlay Visible="@_isOpen" OnClick="ClosePopover" ZIndex="666" AutoClose="true" />
</div>

@code {
    [Parameter, EditorRequired] public required IEnumerable<TItem> Items { get; set; }

    [Parameter] public TransitionFilter<TItem> Value { get; set; } = new();
    [Parameter] public EventCallback<TransitionFilter<TItem>> ValueChanged { get; set; }

    [Parameter] public string Label { get; set; } = "Passaggio di Stato";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Clearable { get; set; } = true;

    [Parameter] public string LeftColumnHeader { get; set; } = "Stato...";
    [Parameter] public string RightColumnHeader { get; set; } = "Periodo...";
    [Parameter] public string NullItemLabel { get; set; } = "Qualsiasi stato";

    private bool _isOpen;

    private bool HasFilterActive => Value.Item is not null || Value.Preset != DatePreset.Preset.None;

    private string GetAdornmentIcon()
    {
        if (HasFilterActive && Clearable && !Disabled)
            return Icons.Material.Filled.Clear;

        return _isOpen ? Icons.Material.Filled.ArrowDropUp : Icons.Material.Filled.ArrowDropDown;
    }

    private async Task HandleAdornmentClick()
    {
        if (Disabled) return;

        if (HasFilterActive && Clearable)
        {
            await ClearSelectionAsync();
        }
        else
        {
            ToggleOpen();
        }
    }

    private void ToggleOpen()
    {
        if (!Disabled) _isOpen = !_isOpen;
    }

    private void ClosePopover() => _isOpen = false;

    private Task OnItemClickedAsync(TItem? newItem)
    {
        var newState = Value with { Item = newItem };
        return ValueChanged.InvokeAsync(newState);
    }

    private Task OnPresetClickedAsync(DatePreset.Preset newPreset)
    {
        var newState = Value with { Preset = newPreset };
        _isOpen = false; 
        return ValueChanged.InvokeAsync(newState);
    }

    private async Task ClearSelectionAsync()
    {
        _isOpen = false;
        await ValueChanged.InvokeAsync(new TransitionFilter<TItem>());
    }

    private string GetDisplayValue()
    {
        if (!HasFilterActive) return string.Empty;

        var itemName = Value.Item is not null ? $"{Value.Item}" : "Qualsiasi";
        var presetName = Value.Preset != DatePreset.Preset.None ? $"{Value.Preset}" : "Sempre";

        return $"{itemName} ({presetName})";
    }
}