@using System.Collections.Immutable
@typeparam TItem

<MudAutocomplete T="TItem"
                 Label="@Label"
                 Placeholder="@Placeholder"
                 Disabled="@Disabled"
                 Value="@SelectedValue"
                 ValueChanged="OnItemSelected"
                 SearchFunc="@SearchFunc"
                 Clearable="false"
                 ResetValueOnEmptyText="true"
                 CoerceText="false"
                 CoerceValue="false"
                 Variant="Variant.Outlined"
                 Margin="Margin.Dense"
                 MinCharacters="1"
                 DebounceInterval="250"
                 Required="@Required"
                 RequiredError="Value is required">
    <ItemTemplate>
        @if (ChildContent is not null)
        {
            @ChildContent(context)
        }
        else
        {
            @($"{context}")
        }
    </ItemTemplate>
</MudAutocomplete>

@code {
    [Parameter, EditorRequired] public required ImmutableArray<TItem> Items { get; set; }
    [Parameter] public TItem? SelectedValue { get; set; }

    [Parameter, EditorRequired] public required EventCallback<TItem?> SelectedValueChanged { get; set; }
    
    [Parameter] public bool Disabled { get; set; } = true;
    [Parameter] public string Label { get; set; } = "Select...";
    [Parameter] public string Placeholder { get; set; } = "Start typing...";
    [Parameter] public bool Required { get; set; } = true;
    
    [Parameter] public RenderFragment<TItem>? ChildContent { get; set; }

    private Task<IEnumerable<TItem>> SearchFunc(string value, CancellationToken _)
    {
        var result = string.IsNullOrWhiteSpace(value) 
            ? Items 
            : Items.Where(item => $"{item}".Trim().StartsWith(value, StringComparison.OrdinalIgnoreCase));
        
        return Task.FromResult(result.OrderBy(item => $"{item}").Take(50));
    }
    
    private async Task OnItemSelected(TItem value)
    {
        if (EqualityComparer<TItem>.Default.Equals(SelectedValue, value)) return;

        await SelectedValueChanged.InvokeAsync(value);
    }
}