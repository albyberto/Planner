@using System.Collections.Immutable
@using Planner.Components.Shared.Filters.Model
@typeparam TItem

<MudAutocomplete T="TItem"
                 Label="@Label"
                 Value="@_selectedItem"
                 ValueChanged="OnItemAddedAsync"
                 SearchFunc="@SearchFunc"
                 ToStringFunc="@(item => item is null ? string.Empty : $"{item}")"
                 Variant="Variant.Outlined"
                 Dense="true"
                 Clearable="true"
                 MinCharacters="1"
                 DebounceInterval="250"
                 ResetValueOnEmptyText="true"
                 Disabled="@Disabled">
    <ItemTemplate>
        @if (ChildContent is not null)
        {
            @ChildContent(context)
        }
        else
        {
            @($"{context}")
        }
    </ItemTemplate>
</MudAutocomplete>

<FilterPillsControl TItem="TItem" @bind-Selection="Selection">
        @if (ChildContent is not null)
        {
            @ChildContent(context)
        }
        else
        {
            @($"{context}")
        }
</FilterPillsControl>

@code {
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter, EditorRequired] public required ImmutableHashSet<TItem> Items { get; set; }

    [Parameter, EditorRequired] public required IFilterSelection<TItem> Selection { get; set; }
    [Parameter] public EventCallback<IFilterSelection<TItem>> SelectionChanged { get; set; }

    [Parameter] public bool Disabled { get; set; }
    [Parameter] public RenderFragment<TItem>? ChildContent { get; set; }

    private TItem? _selectedItem;

    private Task<IEnumerable<TItem>> SearchFunc(string? value, CancellationToken cancellationToken)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return Task.FromResult<IEnumerable<TItem>>(Items.DistinctBy(l => l?.ToString()).Take(50));
        }

        var token = value.Trim();
        var result = Items.Where(l => l is not null && (l.ToString()?.Contains(token, StringComparison.OrdinalIgnoreCase) ?? false)).DistinctBy(l => l?.ToString()).Take(50);

        return Task.FromResult(result);
    }

    private async Task OnItemAddedAsync(TItem? selectedItem)
    {
        _selectedItem = default;

        if (selectedItem is null) return;

        var newSelection = Selection.Add(selectedItem);
        await SelectionChanged.InvokeAsync(newSelection);
    }
}