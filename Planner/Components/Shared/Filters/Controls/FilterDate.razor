@using Planner.Components.Shared.Filters.Model
@using Planner.Extensions
@using Planner.Infrastructure.Domain.Enums

<div class="position-relative w-100">
    <MudTextField T="string"
                  Label="@Label"
                  Text="@GetDisplayValue()"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  ReadOnly="true"
                  Disabled="@Disabled"
                  Adornment="Adornment.End"
                  AdornmentIcon="@GetAdornmentIcon()"
                  OnAdornmentClick="HandleAdornmentClick"
                  @onclick="ToggleOpen"
                  Class="w-100 clickable-input transition-filter-input" />

    <MudPopover Open="@_isOpen"
                AnchorOrigin="Origin.BottomLeft"
                TransformOrigin="Origin.TopLeft"
                RelativeWidth="DropdownWidth.Relative"
                MaxHeight="300"
                Class="mud-elevation-2 rounded-lg harmonized-popover">

        @* Layout a colonna singola, eredita le stesse classi del Transition Filter *@
        <MudStack Spacing="0" Class="picker-layout-single">
            
            <MudList T="Preset" SelectionMode="SelectionMode.SingleSelection" Class="picker-scroll-container">
                @foreach (var option in DatePreset.Options)
                {
                    var isSelected = Value == option.Value;
                    
                    <MudListItem Value="@option.Value" 
                                 Text="@option.Value.ToTitleCase()"
                                 Icon="@(option.Value == Preset.None ? null : Icons.Material.Filled.Circle)"
                                 IconColor="@option.IconColor"
                                 IconSize="Size.Small"
                                 OnClick="@(() => OnPresetClickedAsync(option.Value))"
                                 Class="@(isSelected ? "selected-item" : "custom-list-item")" />
                }
            </MudList>

        </MudStack>
    </MudPopover>

    <MudOverlay Visible="@_isOpen" OnClick="@ClosePopover" ZIndex="666" AutoClose="true" />
</div>

@code {
    [Parameter] public string Label { get; set; } = "Periodo...";
    
    [Parameter] public Preset Value { get; set; } = Preset.None;
    [Parameter] public EventCallback<Preset> ValueChanged { get; set; }

    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Clearable { get; set; } = true;

    private bool _isOpen;

    private bool HasFilterActive => Value != Preset.None;

    private string GetAdornmentIcon() =>
        HasFilterActive && Clearable && !Disabled
            ? Icons.Material.Filled.Clear
            : _isOpen ? Icons.Material.Filled.ArrowDropUp : Icons.Material.Filled.ArrowDropDown;

    private async Task HandleAdornmentClick()
    {
        if (Disabled) return;

        if (HasFilterActive && Clearable)
        {
            await ClearSelectionAsync();
        }
        else
        {
            ToggleOpen();
        }
    }

    private void ToggleOpen()
    {
        if (!Disabled) _isOpen = !_isOpen;
    }

    private void ClosePopover() => _isOpen = false;

    private Task OnPresetClickedAsync(Preset newPreset)
    {
        _isOpen = false; 
        return ValueChanged.InvokeAsync(newPreset);
    }

    private Task ClearSelectionAsync()
    {
        _isOpen = false;
        return ValueChanged.InvokeAsync(Preset.None);
    }

    private string GetDisplayValue() => HasFilterActive 
        ? Value.ToTitleCase() 
        : string.Empty;
}