@typeparam TItem
@using Planner.Components.Shared.Filters.Model
@using Planner.Model

<div class="d-flex flex-row gap-2 w-100">
    @* 1. Tendina dell'Elemento (es. Stato) *@
    <MudSelect T="TItem" 
               Label="@LeftColumnHeader"
               Value="Value.Item"
               ValueChanged="OnItemChangedAsync"
               Variant="Variant.Outlined" 
               Margin="Margin.Dense" 
               Disabled="@Disabled"
               Clearable="true"
               Class="flex-1">
        @foreach (var item in Items)
        {
            <MudSelectItem T="TItem" Value="@item">
                @($"{item}")
            </MudSelectItem>
        }
    </MudSelect>

    @* 2. Tendina del Periodo (si abilita solo se scegli l'elemento a sinistra) *@
    <MudSelect T="DatePreset" 
               Label="@RightColumnHeader"
               Value="Value.Preset"
               ValueChanged="OnPresetChangedAsync"
               Variant="Variant.Outlined" 
               Margin="Margin.Dense" 
               Disabled="@(Disabled || Value.Item is null)"
               Clearable="true"
               Class="flex-1">
        @foreach (DatePreset preset in Enum.GetValues(typeof(DatePreset)))
        {
            <MudSelectItem T="DatePreset" Value="@preset">
                @GetPresetLabel(preset)
            </MudSelectItem>
        }
    </MudSelect>
</div>

@code {
    [Parameter, EditorRequired] public required IEnumerable<TItem> Items { get; set; }
    
    [Parameter] public TransitionFilter<TItem> Value { get; set; } = new();
    [Parameter] public EventCallback<TransitionFilter<TItem>> ValueChanged { get; set; }
    
    [Parameter] public bool Disabled { get; set; }

    [Parameter] public string LeftColumnHeader { get; set; } = "Passato allo stato...";
    [Parameter] public string RightColumnHeader { get; set; } = "Nel periodo...";

    private Task OnItemChangedAsync(TItem? newItem)
    {
        // Se l'utente svuota lo stato (clicca la X), svuotiamo anche il preset
        var newState = newItem is null 
            ? new TransitionFilter<TItem>() 
            : Value with { Item = newItem };
            
        return ValueChanged.InvokeAsync(newState);
    }

    private Task OnPresetChangedAsync(DatePreset newPreset)
    {
        var newState = Value with { Preset = newPreset };
        return ValueChanged.InvokeAsync(newState);
    }

    private string GetPresetLabel(DatePreset preset) => preset switch
    {
        DatePreset.None => "Nessun periodo",
        DatePreset.Today => "Oggi",
        DatePreset.Yesterday => "Ieri",
        DatePreset.LastWeek => "Ultima settimana",
        DatePreset.LastMonth => "Ultimo mese",
        _ => preset.ToString()
    };
}