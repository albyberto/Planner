@using System.Collections.Immutable
@using Planner.Clients
@using Planner.Model
@inject JiraReadClient ReadClient

<InlineMultiSelect TItem="LabelModel"
                   Issue="@Issue"
                   Items="@Issue.Labels"
                   ItemsChanged="@((IReadOnlyCollection<LabelModel> labels) => Issue.Labels = ImmutableList.CreateRange(labels))"
                   LoadItemsAsync="@(async projectKey =>
                                   {
                                       var project = ReadClient.GetProjects().FirstOrDefault(project => project.Key.Equals(projectKey, StringComparison.OrdinalIgnoreCase));
                                       return project != null ? (IReadOnlyList<LabelModel>)await project.GetLabelsAsync() : Array.Empty<LabelModel>();
                                   })"
                   UpdateBuilderAction="@((builder, labels) => builder.SetLabels(labels))"
                   Label="Labels"
                   ChipColor="Color.Secondary"
                   EmptyTooltip="Aggiungi Label"/>

@code {
    [Parameter][EditorRequired] public IssueModel Issue { get; set; } = null!;
}
