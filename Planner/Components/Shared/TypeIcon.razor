@using Planner.Model

@if (!string.IsNullOrEmpty(Type?.IconUrl))
{
    <MudTooltip Text="@Type.Name" Arrow="true">
        <MudImage Src="@Type.IconUrl" Width="20" Height="20" Alt="@Type.Name" Class="d-inline-flex" />
    </MudTooltip>
}

@code {
    [Parameter, EditorRequired] public required IssueTypeModel Type { get; set; } = null!;
}