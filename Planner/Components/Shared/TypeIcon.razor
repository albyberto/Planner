@using Planner.Domain

@if (!string.IsNullOrEmpty(IssueType.IconUrl))
{
    <MudTooltip Text="@IssueType.Name" Arrow="true">
        <MudImage Src="@IssueType.IconUrl" Width="20" Height="20" Alt="@IssueType.Name" Class="d-inline-flex" />
    </MudTooltip>
}

@code {
    [Parameter, EditorRequired] public required IssueType IssueType { get; set; } = null!;
}