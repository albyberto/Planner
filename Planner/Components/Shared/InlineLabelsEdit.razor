@using System.Collections.Immutable
@using Planner.Builders
@using Planner.Clients
@using Planner.Model

@inject JiraReadClient ReadClient
@inject JiraWriteClient WriteClient
@inject ISnackbar Snackbar

@if (_editing)
{
    <MudSelect T="LabelModel"
               MultiSelection="true"
               SelectedValues="_selected"
               SelectedValuesChanged="OnSelectionChanged"
               Open="_isOpen"
               OpenChanged="OnOpenChanged"
               Label="Labels"
               Dense="true"
               Variant="Variant.Outlined"
               Margin="Margin.Dense"
               AnchorOrigin="Origin.BottomLeft"
               CloseIcon="@Icons.Material.Filled.Close"
               ToStringFunc="GetLabelText">
        @foreach (var label in _availableLabels)
        {
            <MudSelectItem T="LabelModel" Value="@label">@label.Label</MudSelectItem>
        }
    </MudSelect>
}
else
{
    <div class="d-inline-flex flex-wrap gap-1 cursor-pointer" @onclick="StartEdit">
        @if (Issue.Labels is { Count: > 0 })
        {
            @foreach (var label in Issue.Labels)
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary" Class="mr-1">
                    @label.Label
                </MudChip>
            }
        }
        else
        {
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">+</MudChip>
        }
    </div>
}

@code {
    [Parameter][EditorRequired] public required IssueModel Issue { get; set; }
    [Parameter] public EventCallback<IssueModel> IssueChanged { get; set; }

    private bool _editing;
    private bool _isOpen;
    private bool _isDirty;
    
    private IReadOnlyCollection<LabelModel> _selected = [];
    private IReadOnlyList<LabelModel> _availableLabels = [];

    private async Task StartEdit()
    {
        var projectKey = Issue.ProjectKey; 
        var project = ReadClient.GetProjects().FirstOrDefault(p => p.Key.Equals(projectKey, StringComparison.OrdinalIgnoreCase));

        if (project is not null)
        {
            _availableLabels = await project.GetLabelsAsync();
        }

        _selected = Issue.Labels;
        
        _isDirty = false; 
        _editing = true;
        _isOpen = true; 
    }

    private void OnSelectionChanged(IReadOnlyCollection<LabelModel> values)
    {
        _selected = values;
        _isDirty = true; 
    }

    private async Task OnOpenChanged(bool isOpen)
    {
        _isOpen = isOpen;
        
        if (!isOpen)
        {
            await SaveAndCloseAsync();
        }
    }

    private async Task SaveAndCloseAsync()
    {
        if (!_isDirty)
        {
            _editing = false;
            return;
        }

        var currentLabels = Issue.Labels;
        var newLabels = _selected.Select(l => l.Value).OrderBy(v => v).ToList();
        var oldLabels = currentLabels.Select(l => l.Value).OrderBy(v => v).ToList();

        if (newLabels.SequenceEqual(oldLabels))
        {
            _editing = false; 
            return;
        }

        try
        {
            var update = new IssueUpdateBuilder().SetLabels(newLabels);
            await WriteClient.UpdateIssueAsync(Issue.Key, update);

            var updatedLabels = _selected.ToImmutableList();
            var updatedIssue = Issue with { Labels = updatedLabels };
            
            await IssueChanged.InvokeAsync(updatedIssue);

            Snackbar.Add($"{Issue.Key} labels aggiornate", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
        finally
        {
            _editing = false;
        }
    }

    private string GetLabelText(LabelModel? label) => label?.Label ?? string.Empty;
}