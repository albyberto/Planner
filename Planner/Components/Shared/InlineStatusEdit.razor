@using Planner.Facades
@using Planner.Model
@inject IssueFacade Facade
@inject ISnackbar Snackbar

@if (_editing)
{
    <MudSelect T="TransitionModel"
               Value="@null"
               ValueChanged="DoTransition"
               Placeholder="@Value.Name"
               Open="_editing"
               OpenChanged="OnOpenChanged"
               Dense="true"
               Variant="Variant.Outlined"
               Margin="Margin.Dense"
               AnchorOrigin="Origin.BottomLeft"
               Class="text-nowrap"
               PopoverClass="text-nowrap"
               CloseIcon="@Icons.Material.Filled.Close"
               ToStringFunc="@(t => t?.Name ?? string.Empty)"
               Style="min-width: 160px;">
        @foreach (var transition in Transitions)
        {
            <MudSelectItem T="TransitionModel" Value="@transition" Class="text-nowrap">
                @transition.Name
            </MudSelectItem>
        }
    </MudSelect>
}
else
{
    <MudChip T="string" Size="Size.Small" Color="@Value.Color" Variant="Variant.Filled" Class="cursor-pointer" OnClick="StartEdit">
        @Value.Name
    </MudChip>
}

@code {
    [Parameter, EditorRequired] public required string IssueKey { get; set; }
    [Parameter, EditorRequired] public required StatusModel Value { get; set; }
    [Parameter] public IReadOnlyList<TransitionModel> Transitions { get; set; } = Array.Empty<TransitionModel>();
    [Parameter] public EventCallback<StatusModel> ValueChanged { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }
    [CascadingParameter(Name = "RefreshIssues")] public Func<Task>? RefreshIssues { get; set; }

    private bool _editing;

    private void StartEdit()
    {
        _editing = true;
    }

    private void OnOpenChanged(bool isOpen)
    {
        if (!isOpen)
        {
            _editing = false;
        }
    }

    private async Task DoTransition(TransitionModel? transition)
    {
        if (transition == null)
        {
            _editing = false;
            return;
        }

        try
        {
            await Facade.TransitionAsync(IssueKey, transition.Id);
            Snackbar.Add($"{IssueKey} → {transition.Name}", Severity.Success);
            
            Value = transition.TargetStatus;
            await ValueChanged.InvokeAsync(Value);

            if (OnChanged.HasDelegate) await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore transizione: {ex.Message}", Severity.Error);
        }
        finally
        {
            _editing = false;
        }
    }

}
