@using Planner.Components.Shared.Filters
@using Planner.Extensions
@using Planner.Infrastructure.Core
@using Planner.Infrastructure.Domain
@using Planner.Model

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudPaper Outlined="true" Class="pa-4 h-100">
                    <MudText Typo="Typo.h6" Class="mb-4">Preset Details</MudText>
                    
                    <MudTextField @bind-Value="_name" 
                                  Label="Preset Name" 
                                  Required="true" 
                                  Variant="Variant.Outlined" 
                                  Margin="Margin.Dense" 
                                  Class="mb-4" />
                                  
                    <MudTextField @bind-Value="_description" 
                                  Label="Description" 
                                  Lines="4"
                                  Variant="Variant.Outlined" 
                                  Margin="Margin.Dense" />
                    
                    <MudSwitch T="bool"
                               @bind-Value="_isDefault" 
                               Color="Color.Primary"
                               Label="Imposta come Default" 
                               Class="mt-4" />
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="8">
                <FiltersControl Collapsable="false" OnCriteriaChanged="OnCriteriaChanged" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="@Cancel">Annulla</MudButton>
        <MudTooltip Text="Save preset">
            <MudIconButton Icon="@Icons.Material.Outlined.Save" Color="Color.Primary" Variant="Variant.Outlined" OnClick="@SaveAsync" Disabled="@string.IsNullOrWhiteSpace(_name)" />
        </MudTooltip>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public PresetItem Model { get; set; } = new();

    [CascadingParameter] public required IMudDialogInstance MudDialog { get; set; }

    [Inject] public required IPresetService PresetService { get; set; }
    [Inject] public required ISnackbar Snackbar { get; set; }

    private string _name = string.Empty;
    private string _description = string.Empty;
    private bool _isDefault;
    
    private SearchCriteria _currentCriteria = SearchCriteria.Empty;

    protected override async Task OnInitializedAsync()
    {
        _name = Model.Name;
        _description = Model.Description;
        _isDefault = Model.Default;

        await MudDialog.SetTitleAsync(Model.Id == Guid.Empty ? "Create New Preset" : "Update Preset");
    }

    private void OnCriteriaChanged(SearchCriteria newCriteria)
    {
        _currentCriteria = newCriteria;
    }

    private async Task SaveAsync()
    {
        try
        {
            var itemToSave = _currentCriteria
                .ToPresetItem(Model.Id, _name, _description) 
                with { Default = _isDefault };

            await PresetService.SaveAsync(itemToSave);

            Snackbar.Add("Preset salvato con successo!", Severity.Success);
            
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore durante il salvataggio: {ex.Message}", Severity.Error);
        }
    }

    private void Cancel() => MudDialog.Cancel();
}