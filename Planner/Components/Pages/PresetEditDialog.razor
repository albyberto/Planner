@using Planner.Components.Shared.Filters
@using Planner.Extensions
@using Planner.Infrastructure.Domain
@using Planner.Mappers
@using Planner.Model
<MudDialog>
    <TitleContent>
        <div class="d-flex justify-space-between align-center">
            <MudText Typo="Typo.h6">
                @(Model.Id == Guid.Empty ? "Create New Preset" : "Update Preset")
            </MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="Cancel" AriaLabel="Chiudi"/>
        </div>
    </TitleContent>

    <DialogContent>
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudPaper Outlined="true" Class="pa-4 h-100 d-flex flex-column">
                    <MudText Typo="Typo.h6" Class="mb-4">Preset Details</MudText>

                    <MudTextField @bind-Value="_name"
                                  Label="Preset Name"
                                  Required="true"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Class="mb-4"/>

                    <MudTextField @bind-Value="_description"
                                  Label="Description"
                                  Lines="4"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"/>

                    <MudSwitch T="bool"
                               @bind-Value="_isDefault"
                               Color="Color.Primary"
                               Label="Imposta come Default"
                               Class="mt-4 mb-4"/>

                    @* Il tasto ora chiama "Submit" in modo sincrono, non salva sul DB *@
                    <MudButton Class="mt-auto"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Outlined.Save"
                               OnClick="Submit"
                               Disabled="@string.IsNullOrWhiteSpace(_name)">
                        Save
                    </MudButton>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="8">
                @* Assicurati che FiltersControl accetti il Criteria iniziale se stai modificando un preset esistente! *@
                <FiltersControl Collapsable="false"
                                ShowPresets="@false"
                                OnCriteriaChanged="OnCriteriaChanged"/>
            </MudItem>
        </MudGrid>
    </DialogContent>
</MudDialog>

@code {
    [Parameter] public PresetItem Model { get; set; } = new();

    [CascadingParameter] public required IMudDialogInstance MudDialog { get; set; }

    private string _name = string.Empty;
    private string _description = string.Empty;
    private bool _isDefault;

    private SearchCriteria _currentCriteria = SearchCriteria.Empty;

    protected override void OnInitialized() {
        _name = Model.Name;
        _description = Model.Description;
        _isDefault = Model.Default;

        // ATTENZIONE: Se stai modificando un Preset esistente, devi caricare i suoi filtri!
        // Presumo tu abbia un mapper inverso (es. Model.ToSearchCriteria()) per estrarre i criteri.
        // Se Model.Criteria è già popolato, convertilo e assegnalo a _currentCriteria qui.
    }

    private void OnCriteriaChanged(SearchCriteria newCriteria) {
        _currentCriteria = newCriteria;
    }

    private void Submit() {
        // Ricostruisce l'Item in memoria
        var itemToReturn = _currentCriteria.ToDomain(Model.Id, _name, _description) with { Default = _isDefault };

        // Passa l'Item alla pagina chiamante, la quale si occuperà di salvare su DB e notificare lo Snackbar
        MudDialog.Close(DialogResult.Ok(itemToReturn));
    }

    private void Cancel() => MudDialog.Cancel();
}