@page "/jira-chat"
@using Planner.Clients
@using Planner.Model
@using Planner.Options
@using Planner.Services
@using Planner.Components.Shared
@using Microsoft.Extensions.Options
@using Planner.Domain
@using JQLBuilder
@using MudBlazor

<PageTitle>Jira Chat</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">
    <MudIcon Icon="@Icons.Material.Filled.Chat" Class="mr-2" />
    Jira Chat
</MudText>

@if (string.IsNullOrWhiteSpace(_me.Email))
{
    <MudAlert Severity="Severity.Warning">
        Configura le proprietà Name ed Email nell'oggetto "Me" in appsettings.json sotto "JiraFilters" per visualizzare le chat.
    </MudAlert>
}
else
{
    @* Add filters to Jira Chat page *@
    <Filters OnFilterChanged="OnFilterChanged" ShowAssigneeFilter="false" />

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
    }
    else if (!_issues.Any())
    {
        <MudAlert Severity="Severity.Info">Nessuna conversazione trovata per @_me.Name con i filtri correnti.</MudAlert>
    }
    else
    {
        <MudStack Spacing="4">
            @foreach (var issue in _issues.OrderByDescending(i => i.Comments.Max(c => c.Created ?? DateTime.MinValue)))
            {
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.h6">
                        <IssueKey Issue="@issue" /> - @issue.Summary
                    </MudText>
                    
                    <MudStack Spacing="3" Class="pa-4" Style="background-color: var(--mud-palette-background-grey); border-radius: 8px;">
                        @foreach (var comment in issue.Comments.OrderBy(c => c.Created))
                        {
                            var isMe = comment.Author.EmailAddress?.Equals(_me.Email, StringComparison.OrdinalIgnoreCase) == true;
                            var isEditing = _editingCommentId == comment.Id && _editingIssueKey == issue.Key;
                            
                            var alignClass = isMe ? "justify-end" : "justify-start";
                            var bubbleColor = isMe ? "var(--mud-palette-success-lighten)" : "var(--mud-palette-surface)";
                            var borderRadius = isMe ? "16px 16px 4px 16px" : "16px 16px 16px 4px";
                            var authorColor = isMe ? "var(--mud-palette-success-darken)" : "var(--mud-palette-primary)";
                            
                            <div class="d-flex w-100 @alignClass">
                                @if (isEditing)
                                {
                                    <MudPaper Elevation="2" Class="pa-3 w-100" Style="border: 2px solid var(--mud-palette-primary);">
                                        <MudTextField T="string" 
                                                      @bind-Value="_editDraft" 
                                                      Label="Modifica commento..." 
                                                      Variant="Variant.Outlined" 
                                                      Margin="Margin.Dense" 
                                                      Lines="3" />
                                        
                                        <div class="d-flex justify-end gap-2 mt-2">
                                            <MudButton Size="Size.Small" OnClick="CancelEdit">Annulla</MudButton>
                                            <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled" OnClick="@(() => SaveEditAsync(issue))" Disabled="@(_savingEdit || string.IsNullOrWhiteSpace(_editDraft))">
                                                @if (_savingEdit) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/> }
                                                Salva
                                            </MudButton>
                                        </div>
                                    </MudPaper>
                                }
                                else
                                {
                                    <MudPaper Elevation="1" 
                                              Style="@($"background-color: {bubbleColor}; border-radius: {borderRadius}; max-width: 80%; padding: 8px 12px; position: relative;")"
                                              @onmouseenter="@(() => _hoveredCommentId = comment.Id)"
                                              @onmouseleave="@(() => _hoveredCommentId = null)">
                                        
                                        @if (!isMe)
                                        {
                                            <div style="@($"color: {authorColor}; font-weight: 600; font-size: 0.8rem; margin-bottom: 4px;")">
                                                @comment.Author.DisplayName
                                            </div>
                                        }
                                        
                                        <div style="font-size: 0.9rem; white-space: pre-wrap; word-break: break-word; line-height: 1.4; color: var(--mud-palette-text-primary);">
                                            @comment.Body
                                        </div>
                                        
                                        <div class="d-flex justify-space-between align-center mt-1">
                                            <div>
                                                @if (isMe && _hoveredCommentId == comment.Id)
                                                {
                                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Default" Class="pa-0 mr-2" OnClick="@(() => StartEdit(issue.Key, comment))" />
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" Class="pa-0" OnClick="@(() => DeleteCommentAsync(issue, comment))" />
                                                }
                                            </div>
                                            <span style="font-size: 0.7rem; color: var(--mud-palette-text-secondary); opacity: 0.8;">
                                                @(comment.Created?.ToString("HH:mm") ?? "")
                                                @if (comment.Updated > comment.Created)
                                                {
                                                    <span class="ml-1">(Modificato)</span>
                                                }
                                            </span>
                                        </div>
                                    </MudPaper>
                                }
                            </div>
                        }
                    </MudStack>
                    
                    <MudDivider Class="my-3"/>
                    
                    <div style="overflow-x: auto; white-space: nowrap; padding-bottom: 8px;" class="mb-2 scrollbar-thin">
                        @foreach (var user in _projectUsers)
                        {
                            <MudChip T="UserModel" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" OnClick="@(() => AppendMentionToDraft(issue.Key, user))">
                                <MudAvatar Size="Size.Small" Class="mr-1">
                                    <MudImage Src="@user._48x48" />
                                </MudAvatar>
                                @user.DisplayName
                            </MudChip>
                        }
                    </div>

                    <div class="d-flex align-center gap-2 mt-2 w-100">
                        <MudTextField T="string"
                                      Value="_draftComments.GetValueOrDefault(issue.Key)" 
                                      ValueChanged="@(v => OnDraftChanged(issue.Key, v))"
                                      Immediate="true"
                                      Label="Scrivi un commento..." 
                                      Variant="Variant.Outlined" 
                                      Margin="Margin.Dense" 
                                      Lines="1" 
                                      MaxLines="5"
                                      Class="flex-grow-1"
                                      OnKeyDown="@(e => HandleKeyDown(e, issue.Key))" />
                                      
                        <MudIconButton Icon="@Icons.Material.Filled.Send" 
                                       Color="Color.Primary" 
                                       Variant="Variant.Filled"
                                       Size="Size.Medium" 
                                       OnClick="@(() => SendCommentAsync(issue))" 
                                       Disabled="@(string.IsNullOrWhiteSpace(_draftComments.GetValueOrDefault(issue.Key)) || _sending.Contains(issue.Key))" />
                    </div>
                </MudPaper>
            }
        </MudStack>
    }
}

@code {
    [Inject] private JiraReadClient ReadClient { get; set; } = default!;
    [Inject] private IOptions<JiraFilterOptions> FilterOptions { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;
    [Inject] private JqlFilterBuilder QueryBuilder { get; set; } = default!;

    [Inject] private JiraWriteClient WriteClient { get; set; } = default!;

    private MeOptions _me = new();
    private bool _loading = true;
    private List<IssueModel> _issues = new();
    private Filter? _currentFilter;
    
    // Reply & Mention State
    private Dictionary<string, string> _draftComments = new();
    private HashSet<string> _sending = new();
    
    private List<UserModel> _projectUsers = new();
    private Dictionary<string, UserModel> _mappedMentions = new();

    protected override async Task OnInitializedAsync()
    {
        _me = FilterOptions.Value.Me;
        if (string.IsNullOrWhiteSpace(_me.Email) && string.IsNullOrWhiteSpace(_me.Name))
        {
            _loading = false;
        }

        try
        {
            var users = new List<UserModel>();
            foreach (var proj in ReadClient.GetProjects())
            {
                users.AddRange(await proj.GetAssigneesAsync());
            }
            _projectUsers = users
                .Where(u => !string.IsNullOrWhiteSpace(u.DisplayName) && !string.IsNullOrWhiteSpace(u.AccountId))
                .DistinctBy(u => u.AccountId)
                .ToList();
        }
        catch { /* Fallback */ }
    }

    // Editing State
    private string? _hoveredCommentId;
    private string? _editingCommentId;
    private string? _editingIssueKey;
    private string _editDraft = string.Empty;
    private bool _savingEdit = false;

    [Inject] private IDialogService DialogService { get; set; } = default!;

    private void AppendMentionToDraft(string issueKey, UserModel user)
    {
        var currentDraft = _draftComments.GetValueOrDefault(issueKey) ?? string.Empty;
        var alias = $"@{user.DisplayName.Replace(" ", "")} ";
        _mappedMentions[alias.TrimEnd()] = user;
        
        _draftComments[issueKey] = currentDraft + alias;
    }

    private void OnDraftChanged(string issueKey, string value)
    {
        _draftComments[issueKey] = value;
    }
    
    // --- Edit Flow ---
    private void StartEdit(string issueKey, IssueCommentModel comment)
    {
        _editingIssueKey = issueKey;
        _editingCommentId = comment.Id;
        _editDraft = comment.Body;
    }

    private void CancelEdit()
    {
        _editingIssueKey = null;
        _editingCommentId = null;
        _editDraft = string.Empty;
    }

    private async Task SaveEditAsync(IssueModel issue)
    {
        if (string.IsNullOrWhiteSpace(_editDraft) || _editingCommentId == null) return;
        try
        {
            _savingEdit = true;
            StateHasChanged();
            
            var adfBody = BuildAdfFromText(_editDraft);
            await WriteClient.UpdateCommentAsync(issue.Key, _editingCommentId, adfBody);

            var commentToUpdate = issue.Comments.FirstOrDefault(c => c.Id == _editingCommentId);
            if (commentToUpdate != null)
            {
                commentToUpdate.Body = _editDraft;
                commentToUpdate.Updated = DateTime.Now;
            }
            
            Snackbar.Add("Commento aggiornato", Severity.Success);
            CancelEdit();
        }
        catch (Exception)
        {
            Snackbar.Add("Errore nell'aggiornamento", Severity.Error);
        }
        finally
        {
            _savingEdit = false;
            StateHasChanged();
        }
    }
    
    // --- Delete Flow ---
    private async Task DeleteCommentAsync(IssueModel issue, IssueCommentModel comment)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Elimina commento", 
            "Sei sicuro di voler eliminare questo commento?", 
            yesText: "Elimina", cancelText: "Annulla");

        if (result == true)
        {
            try
            {
                await WriteClient.DeleteCommentAsync(issue.Key, comment.Id);
                
                var list = issue.Comments.ToList();
                list.RemoveAll(c => c.Id == comment.Id);
                issue.Comments = System.Collections.Immutable.ImmutableList.CreateRange(list);
                
                Snackbar.Add("Commento eliminato", Severity.Success);
                StateHasChanged();
            }
            catch (Exception)
            {
                Snackbar.Add("Errore nell'eliminazione", Severity.Error);
            }
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e, string issueKey)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            if (!string.IsNullOrWhiteSpace(_draftComments.GetValueOrDefault(issueKey)))
            {
                var issue = _issues.FirstOrDefault(i => i.Key == issueKey);
                if (issue != null) await SendCommentAsync(issue);
            }
        }
    }

    private class MentionToken { public string Text { get; set; } = ""; public bool IsMention { get; set; } }

    private List<MentionToken> TokenizeMentions(string draft)
    {
        var tokens = new List<MentionToken>();
        string pattern = @"(@\w+)"; 
        var matches = System.Text.RegularExpressions.Regex.Matches(draft, pattern);
        
        int lastIndex = 0;
        foreach (System.Text.RegularExpressions.Match match in matches)
        {
            if (match.Index > lastIndex)
            {
                tokens.Add(new MentionToken { Text = draft.Substring(lastIndex, match.Index - lastIndex), IsMention = false });
            }
            
            tokens.Add(new MentionToken { Text = match.Value, IsMention = true });
            lastIndex = match.Index + match.Length;
        }
        
        if (lastIndex < draft.Length)
        {
            tokens.Add(new MentionToken { Text = draft.Substring(lastIndex), IsMention = false });
        }
        
        return tokens;
    }

    private object BuildAdfFromText(string text)
    {
        var contentList = new List<object>();
        var tokens = TokenizeMentions(text);

        foreach (var token in tokens)
        {
            if (token.IsMention && _mappedMentions.TryGetValue(token.Text, out var user))
            {
                contentList.Add(new
                {
                    type = "mention",
                    attrs = new { id = user.AccountId, text = token.Text }
                });
            }
            else
            {
                contentList.Add(new { type = "text", text = token.Text });
            }
        }

        return new
        {
            version = 1,
            type = "doc",
            content = new[]
            {
                new { type = "paragraph", content = contentList.ToArray() }
            }
        };
    }

    private async Task SendCommentAsync(IssueModel issue)
    {
        var draft = _draftComments.GetValueOrDefault(issue.Key);
        if (string.IsNullOrWhiteSpace(draft)) return;

        try
        {
            _sending.Add(issue.Key);
            StateHasChanged();

            var adfBody = BuildAdfFromText(draft);
            var newComment = await WriteClient.AddCommentAsync(issue.Key, adfBody);
            
            if (newComment != null)
            {
                var list = issue.Comments.ToList();
                list.Add(newComment);
                issue.Comments = System.Collections.Immutable.ImmutableList.CreateRange(list);
            }
            
            Snackbar.Add("Commento inviato regolarmente", Severity.Success);
            _draftComments[issue.Key] = string.Empty;
        }
        catch (Exception ex)
        {
            Snackbar.Add("Errore durante l'invio del commento", Severity.Error);
        }
        finally
        {
            _sending.Remove(issue.Key);
            StateHasChanged();
        }
    }

    private async Task OnFilterChanged(Filter filter)
    {
        if (string.IsNullOrWhiteSpace(_me.Email)) return;

        _currentFilter = filter;
        await LoadIssuesAsync();
    }

    private async Task LoadIssuesAsync()
    {
        if (_currentFilter == null) return;

        try
        {
            _loading = true;
            StateHasChanged();

            // 1. Build the base query using the selected filters via JqlFilterBuilder
            var baseJqlString = QueryBuilder.BuildDashboardQuery(_currentFilter);
            
            // 2. Build the Jira Chat specific query via JQLBuilder
            var meUser = (JQLBuilder.Types.JqlTypes.JqlHistoricalJqlUser)_me.Email;
            var chatQuery = JQLBuilder.JqlBuilder.Query
                .Where(f => f.User.Assignee == meUser | f.User.Reporter == meUser | f.Text.Comment.Contains(_me.Name));
            
            var chatJqlString = chatQuery.ToString() + " ORDER BY updated DESC";
            
            // Combine both 
            var combinedJql = string.IsNullOrWhiteSpace(baseJqlString) ? chatJqlString : $"({baseJqlString.Replace(" ORDER BY updated DESC", "")}) AND {chatJqlString}";

            var fetchedIssues = await ReadClient.GetIssuesAsync(combinedJql);
            
            // Local fallback logic to ensure exact matches in Comments Body or Author DisplayName 
            // Also filter out any issue that doesn't actually have any comment.
            _issues = fetchedIssues.Where(i => 
                i.Comments.Any() &&
                ((i.Assignee?.EmailAddress?.Equals(_me.Email, StringComparison.OrdinalIgnoreCase) == true) ||
                 i.Comments.Any(c => c.Body.Contains(_me.Name, StringComparison.OrdinalIgnoreCase) || 
                                     c.Author.EmailAddress?.Equals(_me.Email, StringComparison.OrdinalIgnoreCase) == true))
            ).ToList();
            
            // Initialize draft states for new issues
            foreach (var i in _issues)
            {
                _draftComments.TryAdd(i.Key, string.Empty);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Errore durante il caricamento della Jira Chat", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }
}
