@page "/jira-chat"
@using Planner.Clients
@using Planner.Model
@using Planner.Options
@using Microsoft.Extensions.Options

<PageTitle>Jira Chat</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">
    <MudIcon Icon="@Icons.Material.Filled.Chat" Class="mr-2" />
    Jira Chat
</MudText>

@if (string.IsNullOrWhiteSpace(_me))
{
    <MudAlert Severity="Severity.Warning">
        Configura la proprietà "Me" in appsettings.json sotto "JiraFilters" per visualizzare le chat.
    </MudAlert>
}
else if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
}
else if (!_issues.Any())
{
    <MudAlert Severity="Severity.Info">Nessuna conversazione trovata per @_me.</MudAlert>
}
else
{
    <MudStack Spacing="4">
        @foreach (var issue in _issues)
        {
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6">
                    <IssueKey Issue="@issue" /> - @issue.Summary
                </MudText>
                
                <MudDivider Class="my-3"/>
                
                <MudStack Spacing="3">
                    @foreach (var comment in issue.Comments.OrderBy(c => c.Created))
                    {
                        var isMe = comment.Author.DisplayName?.Contains(_me, StringComparison.OrdinalIgnoreCase) == true;
                        <div class="d-flex @(isMe ? "justify-end" : "justify-start")">
                            <MudPaper Class="pa-3" Style="@(isMe ? "background-color: var(--mud-palette-primary-lighten); max-width: 80%;" : "background-color: var(--mud-palette-background-grey); max-width: 80%;")" Elevation="1">
                                <MudText Typo="Typo.caption" Color="@(isMe ? Color.Primary : Color.Secondary)" Class="mb-1 d-block">
                                    <strong>@comment.Author.DisplayName</strong> - @(comment.Created?.ToString("g") ?? "")
                                </MudText>
                                <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@comment.Body</MudText>
                            </MudPaper>
                        </div>
                    }
                    @if (!issue.Comments.Any())
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Nessun commento.</MudText>
                    }
                </MudStack>
            </MudPaper>
        }
    </MudStack>
}

@code {
    [Inject] private JiraReadClient ReadClient { get; set; } = default!;
    [Inject] private IOptions<JiraFilterOptions> FilterOptions { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private string _me = string.Empty;
    private bool _loading = true;
    private List<IssueModel> _issues = new();

    protected override async Task OnInitializedAsync()
    {
        _me = FilterOptions.Value.Me;
        if (string.IsNullOrWhiteSpace(_me))
        {
            _loading = false;
            return;
        }

        try
        {
            var safeMe = _me.Replace("\"", "\\\"");
            var query = $"(assignee = \"{safeMe}\" OR reporter = \"{safeMe}\" OR comment ~ \"\\\"{safeMe}\\\"\") ORDER BY updated DESC";
            
            var fetchedIssues = await ReadClient.GetIssuesAsync(query);
            
            _issues = fetchedIssues.Where(i => 
                (i.Assignee?.DisplayName?.Contains(_me, StringComparison.OrdinalIgnoreCase) == true) ||
                i.Comments.Any(c => c.Body.Contains(_me, StringComparison.OrdinalIgnoreCase) || 
                                    c.Author.DisplayName?.Contains(_me, StringComparison.OrdinalIgnoreCase) == true)
            ).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Errore durante il caricamento della Jira Chat", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}
