@page "/home"

<PageTitle>Home - Planner</PageTitle>

<div class="d-flex align-center mb-6">
    <MudIcon Icon="@Icons.Material.Filled.Rocket" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
    <div>
        <MudText Typo="Typo.h3">Planner</MudText>
        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
            Monitora il carico di lavoro del team e lo stato delle release Jira
        </MudText>
    </div>
</div>

<MudDivider Class="mb-6" />

<MudGrid Spacing="4">
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="3" Class="d-flex flex-column mud-height-full">
            <MudCardHeader>
                <CardHeaderAvatar>
                    <MudAvatar Color="Color.Primary" Variant="Variant.Filled">
                        <MudIcon Icon="@Icons.Material.Filled.Dashboard" />
                    </MudAvatar>
                </CardHeaderAvatar>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Dashboard</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Panoramica team</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body2">
                    Visualizza il carico di lavoro di ogni membro del team con stime, tempo speso, rimanente e le Fix Version assegnate.
                </MudText>
            </MudCardContent>
            <MudCardActions>
                <MudButton Href="dashboard" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           StartIcon="@Icons.Material.Filled.ArrowForward">
                    Apri Dashboard
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="3" Class="d-flex flex-column mud-height-full">
            <MudCardHeader>
                <CardHeaderAvatar>
                    <MudAvatar Color="Color.Secondary" Variant="Variant.Filled">
                        <MudIcon Icon="@Icons.Material.Filled.NewReleases" />
                    </MudAvatar>
                </CardHeaderAvatar>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Per Fix Version</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Dettaglio release</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body2">
                    Issue raggruppate per Fix Version con totali di stima, tempo speso e rimanente per ogni release.
                </MudText>
            </MudCardContent>
            <MudCardActions>
                <MudButton Href="by-version" Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true"
                           StartIcon="@Icons.Material.Filled.ArrowForward">
                    Apri per Version
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="3" Class="d-flex flex-column mud-height-full">
            <MudCardHeader>
                <CardHeaderAvatar>
                    <MudAvatar Color="Color.Tertiary" Variant="Variant.Filled">
                        <MudIcon Icon="@Icons.Material.Filled.People" />
                    </MudAvatar>
                </CardHeaderAvatar>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Per Assignee</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Dettaglio persone</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body2">
                    Issue raggruppate per assegnatario con totali individuali e dettaglio Fix Version per ogni task.
                </MudText>
            </MudCardContent>
            <MudCardActions>
                <MudButton Href="by-assignee" Variant="Variant.Filled" Color="Color.Tertiary" FullWidth="true"
                           StartIcon="@Icons.Material.Filled.ArrowForward">
                    Apri per Assignee
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>

<MudDivider Class="my-6" />

<MudPaper Class="pa-4" Elevation="1">
    <MudGrid>
        <MudItem xs="12" md="4" Class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.FilterList" Class="mr-2" Color="Color.Secondary" />
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                <b>6 stati filtrabili:</b> Backlog, To Do, In Progress, Paused, In Review, Done
            </MudText>
        </MudItem>
        <MudItem xs="12" md="4" Class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.Speed" Class="mr-2" Color="Color.Secondary" />
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                <b>Time tracking:</b> Stima originale, tempo speso, rimanente
            </MudText>
        </MudItem>
        <MudItem xs="12" md="4" Class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.Sync" Class="mr-2" Color="Color.Secondary" />
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                <b>Dati live</b> dalla Jira REST API v3
            </MudText>
        </MudItem>
    </MudGrid>
</MudPaper>
