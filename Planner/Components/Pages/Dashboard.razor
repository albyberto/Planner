@page "/"
@page "/dashboard"
@page "/dashboard/{Email}"
@using System.Collections.Immutable
@using Planner.Clients
@using Planner.Domain
@using Planner.Model
@using Planner.Services

<PageTitle>Dashboard</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">
    <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="mr-2" />
    @_title
</MudText>

<Filters OnFilterChanged="Search" ShowAssigneeFilter="@_showAssigneeFilter"/>

<ul>
@foreach (var issue in _issues)
{
    <li>@issue.Key</li>
}
</ul>

@inject JiraClient Client
@inject JqlFilterBuilder QueryBuilder
@inject ISnackbar Snackbar

@code {
    [Parameter] public string? Email { get; set; }
    
    private ImmutableList<Issue> _issues = [];
    private string _title = "Team Dashboard";
    private bool _showAssigneeFilter = true;
    private bool _isUnassignedRoute;
    private string? _decodedEmail;

    protected override async Task OnParametersSetAsync()
    {
        _isUnassignedRoute = false;
        _decodedEmail = null;
        _showAssigneeFilter = string.IsNullOrEmpty(Email);

        if (string.IsNullOrEmpty(Email))
        {
            _title = "Team Dashboard";
        }
        else if (Email.Equals("unassigned", StringComparison.OrdinalIgnoreCase))
        {
            _title = "Non Assegnate";
            _isUnassignedRoute = true;
        }
        else
        {
            _decodedEmail = Uri.UnescapeDataString(Email);
            var users = await Client.GetProjectAssigneesAsync();
            var name = users.FirstOrDefault(u => u.EmailAddress.Equals(_decodedEmail, StringComparison.OrdinalIgnoreCase))?.DisplayName ?? _decodedEmail;
            _title = $"Dashboard — {name}";
        }
    }

    private async Task Search(Filter filter)
    {
        try 
        {
            if (_isUnassignedRoute)
            {
                filter = filter with { Assignees = [], IncludeUnassigned = true };
            }
            else if (_decodedEmail is not null)
            {
                filter = filter with { Assignees = [_decodedEmail], IncludeUnassigned = false };
            }

            var jql = QueryBuilder.BuildDashboardQuery(filter);
            _issues = await Client.GetIssuesAsync(jql);
        }
        catch (Exception)
        {
            Snackbar.Add("Errore durante il recupero delle issue.", Severity.Error);
        }
    }
}
