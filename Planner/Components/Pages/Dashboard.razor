@page "/"
@page "/dashboard"
@page "/dashboard/{Email}"
@using Planner.Domain
@using Planner.Extensions

<DashboardLayout Title="Dashboard" Email="@Email">
    @{
        var stats = new TimeStats(context);
        var groups = GroupByFixVersion(context);
    }

    @* ───── Summary strip ───── *@
    <MudGrid Spacing="3" Class="mb-4 align-center">
        <MudItem>
            <MudChip T="string" Icon="@Icons.Material.Filled.Schedule" Color="Color.Primary"
                     Variant="Variant.Filled" Size="Size.Large">
                Estimate @stats.OriginalEstimate.ToJiraTime()
            </MudChip>
        </MudItem>
        <MudItem>
            <MudChip T="string" Icon="@Icons.Material.Filled.Timer" Color="Color.Info"
                     Variant="Variant.Filled" Size="Size.Large">
                Spent @stats.TimeSpent.ToJiraTime()
            </MudChip>
        </MudItem>
        <MudItem>
            <MudChip T="string" Icon="@Icons.Material.Filled.HourglassBottom"
                     Color="@(stats.IsOverBudget ? Color.Error : Color.Success)"
                     Variant="Variant.Filled" Size="Size.Large">
                @(stats.IsOverBudget ? $"Over -{stats.OverBudgetAmount.ToJiraTime()}" : $"Left {stats.Remaining.ToJiraTime()}")
            </MudChip>
        </MudItem>
        <MudItem>
            <MudProgressLinear Value="@stats.ProgressPercent"
                               Color="@(stats.IsOverBudget ? Color.Error : Color.Primary)"
                               Rounded="true" Size="Size.Medium" />
        </MudItem>
        <MudItem>
            <MudText Typo="Typo.body2" Color="@(stats.IsOverBudget ? Color.Error : Color.Default)">
                @($"{stats.ProgressPercent:F0}%")
            </MudText>
        </MudItem>
    </MudGrid>

    @* ───── Fix Version groups ───── *@
    @foreach (var group in groups)
    {
        var g = new TimeStats(group.Issues);

        <MudPaper Class="pa-4 mb-4" Elevation="2">
            @* header *@
            <MudGrid Spacing="2" Class="mb-3 align-center">
                <MudItem>
                    <MudIcon Icon="@Icons.Material.Filled.NewReleases" Size="Size.Small" Color="Color.Primary" />
                </MudItem>
                <MudItem>
                    <MudText Typo="Typo.subtitle1"><b>@group.VersionName</b></MudText>
                </MudItem>
                <MudItem>
                    @* Spazio flessibile per spingere i chip a destra *@
                </MudItem>
                <MudItem>
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text">@g.OriginalEstimate.ToJiraTime()</MudChip>
                </MudItem>
                <MudItem>
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">@g.TimeSpent.ToJiraTime()</MudChip>
                </MudItem>
                <MudItem>
                    <MudChip T="string" Size="Size.Small" Color="@(g.IsOverBudget ? Color.Error : Color.Success)" Variant="Variant.Text">
                        @(g.IsOverBudget ? $"-{g.OverBudgetAmount.ToJiraTime()}" : g.Remaining.ToJiraTime())
                    </MudChip>
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudProgressLinear Value="@g.ProgressPercent"
                                       Color="@(g.IsOverBudget ? Color.Error : Color.Primary)"
                                       Rounded="true" Size="Size.Small" />
                </MudItem>
            </MudGrid>

            @* tabella *@
            <MudTable Items="@group.Issues" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                <HeaderContent>
                    <MudTh Class="mud-text-align-center"></MudTh>
                    <MudTh>Key</MudTh>
                    <MudTh>Summary</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh Class="mud-text-align-end">Est</MudTh>
                    <MudTh Class="mud-text-align-end">Spent</MudTh>
                    <MudTh Class="mud-text-align-end">Left</MudTh>
                    <MudTh>Components</MudTh>
                    <MudTh>Labels</MudTh>
                </HeaderContent>
                <RowTemplate Context="issue">
                    @{
                        // Un'unica riga per calcolare tutto!
                        var issueStats = new TimeStats(issue);
                    }
                    <MudTd DataLabel="Type" Class="mud-text-align-center">
                        <TypeIcon IssueType="@issue.Fields.IssueType" />
                    </MudTd>
                    <MudTd DataLabel="Key">
                        <IssueKey Issue="@issue" />
                    </MudTd>
                    <MudTd DataLabel="Summary">
                        <MudText Typo="Typo.body2">@issue.Fields.Summary</MudText>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <StatusBadge Status="@issue.Fields.Status" />
                    </MudTd>
                    <MudTd DataLabel="Est" Class="mud-text-align-end">
                        @issueStats.OriginalEstimate.ToJiraTime()
                    </MudTd>
                    <MudTd DataLabel="Spent" Class="mud-text-align-end mud-info-text">
                        @issueStats.TimeSpent.ToJiraTime()
                    </MudTd>
                    <MudTd DataLabel="Left" Class="@(issueStats.IsOverBudget ? "mud-text-align-end mud-error-text" : "mud-text-align-end mud-success-text")">
                        @(issueStats.IsOverBudget ? $"-{issueStats.OverBudgetAmount.ToJiraTime()}" : issueStats.Remaining.ToJiraTime())
                    </MudTd>
                    <MudTd DataLabel="Components">
                        @foreach (var c in issue.Fields.Components ?? [])
                        {
                            <ComponentChip Component="@c" />
                        }
                    </MudTd>
                    <MudTd DataLabel="Labels">
                        @foreach (var l in issue.Fields.Labels ?? [])
                        {
                            <LabelChip Label="@l" />
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
</DashboardLayout>

@code {
    [Parameter] public string? Email { get; set; }

    private static IEnumerable<(string VersionName, List<Issue> Issues)> GroupByFixVersion(IEnumerable<Issue> issues)
    {
        return issues
            .SelectMany(issue => issue.Fields.FixVersions is { Count: > 0 }
                ? issue.Fields.FixVersions.Select(v => (Version: v.Name, Issue: issue))
                : [(Version: "Senza Fix Version", Issue: issue)])
            .GroupBy(tuple => tuple.Version)
            .OrderBy(group => group.Key)
            .Select(group => (group.Key, group.Select(x => x.Issue).ToList()));
    }

    private record TimeStats(int OriginalEstimate, int TimeSpent)
    {
        public TimeStats(IReadOnlyCollection<Issue> issues) 
            : this(issues.Sum(i => i.GetOriginalEstimate()), issues.Sum(i => i.GetTimeSpent())) { }
    
        public TimeStats(Issue issue) 
            : this(issue.GetOriginalEstimate(), issue.GetTimeSpent()) { }
    
        public int Remaining => Math.Max(OriginalEstimate - TimeSpent, 0);
        public bool IsOverBudget => OriginalEstimate > 0 && TimeSpent > OriginalEstimate;
        public int OverBudgetAmount => IsOverBudget ? TimeSpent - OriginalEstimate : 0;
        public double ProgressPercent => OriginalEstimate > 0 ? Math.Min((double)TimeSpent / OriginalEstimate * 100, 100) : 0;
    }
}