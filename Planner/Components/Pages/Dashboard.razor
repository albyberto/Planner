@page "/"
@page "/dashboard"
@page "/dashboard/{Email}"
@using System.Collections.Immutable
@using Planner.Extensions
@using Planner.Model

<ReactivePage Title="Dashboard" Context="issues">
    @{
        var stats = issues.GetTimeStats();
    }

    @* ───── Summary globale calcolato su TUTTE le issue ───── *@
    <MudGrid Spacing="3" Class="mb-6 align-center">
        <MudItem xs="12" md="4">
            <MudChip T="string" Icon="@Icons.Material.Outlined.Schedule" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">
                Estimate @stats.FormattedEstimate
            </MudChip>
            <MudChip T="string" Icon="@Icons.Material.Outlined.Timer" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small">
                Spent @stats.FormattedTotalSpent
            </MudChip>
            <MudChip T="string" Icon="@Icons.Material.Outlined.HourglassBottom" Color="@(stats.IsOverBudget ? Color.Error : Color.Success)" Variant="Variant.Outlined" Size="Size.Small">
                @(stats.IsOverBudget ? $"Over {stats.FormattedRemaining}" : $"Left {stats.FormattedRemaining}")
            </MudChip>
        </MudItem>
        <MudItem xs="12" md="8">
            <TimeProgressBar Stats="@stats" Size="Size.Small" />
        </MudItem>
    </MudGrid>

    <MudPaper Class="pa-4" Elevation="1">
        @* 2. Passiamo i dati grezzi *@
        <MudTable Items="@issues" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
            <HeaderContent>
                <MudTh>
                    <MudTableSortLabel SortBy="new Func<DashboardIssueModel, object>(x => x.Key)">Key</MudTableSortLabel>
                </MudTh>
                <MudTh>
                    <MudTableSortLabel SortBy="new Func<DashboardIssueModel, object>(x => x.Summary)">Summary</MudTableSortLabel>
                </MudTh>
                <MudTh>
                    @* 3. Gestione dei null: se la data manca, la consideriamo "piccolissima" per non rompere l'ordinamento *@
                    <MudTableSortLabel SortBy="new Func<DashboardIssueModel, object>(x => x.StartDate ?? DateOnly.MinValue)">
                        Start Date
                    </MudTableSortLabel>
                </MudTh>
                <MudTh>
                    @* 4. LA MAGIA È QUI: InitialDirection fa l'ordinamento in automatico al caricamento della pagina *@
                    <MudTableSortLabel InitialDirection="SortDirection.Descending" SortBy="new Func<DashboardIssueModel, object>(x => x.EndDate ?? DateOnly.MinValue)">
                        End Date
                    </MudTableSortLabel>
                </MudTh>
            </HeaderContent>
            
            <RowTemplate Context="issue">
                <MudTd DataLabel="Key">@issue.Key</MudTd>
                <MudTd DataLabel="Summary">@issue.Summary</MudTd>
                <MudTd DataLabel="Start Date">@issue.StartDate?.ToString("d")</MudTd>
                <MudTd DataLabel="End Date">@issue.EndDate?.ToString("d")</MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>

</ReactivePage>

@code {
    [Parameter] public string? Email { get; set; }
}