@page "/test"
@using System.Collections.Immutable
@using Planner.Components.Shared.Filters
@using Planner.Model
@using Planner.Stores
@implements IDisposable
@inject IssueStore IssueStore

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">Jira Dashboard</MudText>

    <FiltersControl PageKey="@_pageKey" />

    <MudTable Items="@_issues" Hover="true" Striped="true" Loading="@_isLoading" Class="mt-6">
        <HeaderContent>
            <MudTh>Key</MudTh>
            <MudTh>Summary</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Assignee</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Key">@context.Key</MudTd>
            <MudTd DataLabel="Summary">@context.Summary</MudTd>
            <MudTd DataLabel="Type">@context.Type?.Name</MudTd>
            <MudTd DataLabel="Status">@context.Status?.Name</MudTd>
            <MudTd DataLabel="Assignee">@context.Assignee?.DisplayName</MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>Nessun ticket trovato con i filtri correnti.</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText>Caricamento dati da Jira in corso...</MudText>
        </LoadingContent>
    </MudTable>
</MudContainer>

@code {
    // Generiamo una chiave univoca per questa istanza della pagina.
    // Se l'utente apre la dashboard in 2 tab diversi del browser, 
    // avranno due Guid separati e non si pesteranno i piedi.
    private readonly Guid _pageKey = Guid.NewGuid();
    
    private ImmutableArray<IssueModel> _issues = [];
    private IDisposable? _storeSubscription;
    private bool _isLoading = true;

    protected override void OnInitialized()
    {
        // Ci iscriviamo all'IssueStore per ricevere i dati calcolati dal BackgroundService.
        // Grazie all'infrastruttura di DynamicQueryStoreBase, la prima volta che chiamiamo Observe()
        // verrà inizializzato il BehaviorSubject nel dizionario interno.
        _storeSubscription = IssueStore.Observe(_pageKey).Subscribe(issues =>
        {
            // Essendo chiamati da un thread in background (il BackgroundService),
            // dobbiamo usare InvokeAsync per rientrare nel SynchronizationContext di Blazor
            InvokeAsync(() =>
            {
                _issues = issues;
                _isLoading = false;
                StateHasChanged();
            });
        });
    }

    public void Dispose()
    {
        // QUANDO L'UTENTE CAMBIA PAGINA:
        // Chiamando .Dispose() sulla subscription, scatta la Return Action che hai 
        // messo nel Observable.Create di DynamicQueryStoreBase.
        // Questo andrà a fare ReleaseInternal(_pageKey), decrementando il refcount 
        // e liberando istantaneamente la memoria!
        _storeSubscription?.Dispose();
    }
}